uci_batch_init() { : > "${UCI_BATCH_FILE}"; }

uci_batch_add() { echo "$*" >> "${UCI_BATCH_FILE}"; }

# B14: Idempotenz - managed sections in angegebener Config löschen
uci_delete_managed_sections() {
    local config="$1"
    local sections
    sections="$(uci show "${config}" 2>/dev/null | grep "\.${MANAGED_MARKER}='1'" | cut -d'.' -f1-2 | sort -u)"
    for sec in ${sections}; do
        uci_batch_add "delete ${sec}"
        log_info "Idempotenz: lösche managed section ${sec}"
    done
}

