    uci_batch_add "set network.lan.netmask='${lan_mask}'"
    uci_batch_add "set network.lan.dns='${CFG_DNS_PRIMARY} ${CFG_DNS_SECONDARY}'"
}

render_mgmt_interface() {
    [ -z "${CFG_NODE_MGMT_IP}" ] && { log_warn "mgmt_ip fehlt - kein mgmt-Interface"; return 0; }
    local mgmt_pfx="${CFG_IP_MGMT_SUBNET##*/}"
    local mgmt_mask; mgmt_mask="$(prefix_to_mask "${mgmt_pfx}")"
    log_step "Render: mgmt (br-lan.${CFG_VLAN_MGMT}, ${CFG_NODE_MGMT_IP})"
    uci_batch_add "set network.mgmt=interface"
