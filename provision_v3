# =============================================================================
# APPLY (B09: LOGREAD_LINES_BEFORE; B19: Reload-RC direkt geprüft)
# =============================================================================
apply_config() {
    log_step "Wende UCI-Konfiguration an"
    local cfg_list="system wireless network"
    [ "${CHANGES_FIREWALL}" -eq 1 ] && cfg_list="${cfg_list} firewall"
    [ "${CHANGES_DHCP}" -eq 1 ]     && cfg_list="${cfg_list} dhcp"

    # B09: Logzeilen vor Apply merken (für zeitfensterbasierte logread-Analyse)
    LOGREAD_LINES_BEFORE="$(logread 2>/dev/null | wc -l)"
    log_info "logread Baseline: ${LOGREAD_LINES_BEFORE} Zeilen"

    local sum_before sum_after
    sum_before="$(sha256sum /etc/config/wireless /etc/config/network 2>/dev/null)"

    local uci_out uci_rc
    uci_out="$(uci batch < "${UCI_BATCH_FILE}" 2>&1)"
    uci_rc=$?
    echo "${uci_out}" >> "${MAIN_LOG}"
    [ -n "${uci_out}" ] && log_info "uci batch output: ${uci_out}"
    if [ "${uci_rc}" -ne 0 ]; then
        log_fail "uci batch fehlgeschlagen (rc=${uci_rc}): ${uci_out}"
        return 1
    fi

    for cfg in ${cfg_list}; do
        if ! uci commit "${cfg}" 2>/dev/null; then
            log_warn "uci commit ${cfg}: keine Änderung oder Fehler"
        else
            log_ok "uci commit ${cfg}: OK"
        fi
    done

    sum_after="$(sha256sum /etc/config/wireless /etc/config/network 2>/dev/null)"
    APPLY_TIME="$(date +%s)"

    # B19: Reload-Return-Code direkt prüfen (kein tee-Masking)
    local rc
    if [ "${sum_before}" != "${sum_after}" ] || [ "${CHANGES_NETWORK}" -eq 1 ]; then
        log_step "Reloading: network"
        /etc/init.d/network reload >> "${MAIN_LOG}" 2>&1
        rc=$?
        [ "${rc}" -ne 0 ] && log_warn "network reload Exit-Code: ${rc}"
        sleep 3
    fi

    if [ "${CHANGES_WIRELESS}" -eq 1 ]; then
        log_step "Reloading: wireless"
        wifi reload >> "${MAIN_LOG}" 2>&1
        rc=$?
        [ "${rc}" -ne 0 ] && log_warn "wifi reload Exit-Code: ${rc}"
        sleep "${HEALTHCHECK_SLEEP}"
    fi

    if [ "${CHANGES_FIREWALL}" -eq 1 ]; then
        log_step "Reloading: firewall"
        /etc/init.d/firewall reload >> "${MAIN_LOG}" 2>&1
        rc=$?
        [ "${rc}" -ne 0 ] && log_warn "firewall reload Exit-Code: ${rc}"
    fi

    if [ "${CHANGES_DHCP}" -eq 1 ]; then
        log_step "Restarting: dnsmasq"
        /etc/init.d/dnsmasq restart >> "${MAIN_LOG}" 2>&1
        rc=$?
        [ "${rc}" -ne 0 ] && log_warn "dnsmasq restart Exit-Code: ${rc}"
    fi

    log_ok "Apply abgeschlossen (APPLY_TIME=${APPLY_TIME})"
    return 0
}

# =============================================================================
# HEALTHCHECK (B09/B10: zeitfensterbasiert + Hard Fail)
# =============================================================================
check_wireless_up() {
    log_step "Healthcheck: WLAN-Interfaces via ubus"
    local retries=0 max_retries=6

    while [ "${retries}" -lt "${max_retries}" ]; do
        local status; status="$(ubus call network.wireless status 2>/dev/null)"
        if [ -n "${status}" ]; then
            case "${PROFILE}" in
                ap_roaming)
                    # SSID + AP-Mode + nicht disabled prüfen
                    if echo "${status}" | grep -q '"mode":"ap"' && \
                       echo "${status}" | grep -q "\"${CFG_SSID_MAIN}\""; then
                        log_ok "Healthcheck: AP-Mode + SSID '${CFG_SSID_MAIN}' aktiv"
                        return 0
                    fi
                    ;;
                mesh_11s_backhaul)
                    if echo "${status}" | grep -q '"mode":"mesh"' && \
                       echo "${status}" | grep -q "\"${CFG_SSID_MESH}\""; then
                        log_ok "Healthcheck: Mesh-Interface + mesh_id aktiv"
                        return 0
                    fi
                    ;;
                client_backhaul)
                    if echo "${status}" | grep -q '"mode":"sta"'; then
                        log_ok "Healthcheck: STA-Interface aktiv"
                        return 0
                    fi
                    ;;
                guest_isolated)
                    if echo "${status}" | grep -q "\"${CFG_SSID_GUEST}\"" && \
                       echo "${status}" | grep -q '"mode":"ap"'; then
                        log_ok "Healthcheck: Guest-SSID + AP-Mode aktiv"
                        return 0
                    fi
                    ;;
            esac
        fi
        retries=$((retries + 1))
        log_info "Healthcheck: Warte auf WLAN... ${retries}/${max_retries}"
        sleep 5
    done

    log_fail "Healthcheck: WLAN-Interface nach $((max_retries * 5))s nicht bereit"
    return 1
}

check_bridges_up() {
    log_step "Healthcheck: Bridge/VLAN"
    if ! ip link show br-lan >/dev/null 2>&1; then
        log_fail "Healthcheck: br-lan nicht gefunden"
        return 1
    fi
    log_ok "Healthcheck: br-lan UP"

    if [ "${PROFILE}" = "guest_isolated" ]; then
        if ! ip link show br-guest >/dev/null 2>&1; then
            log_fail "Healthcheck: br-guest nicht gefunden"
            return 1
        fi
        log_ok "Healthcheck: br-guest UP"
    fi
    return 0
}

# B09/B10: zeitfensterbasiert + Hard Fail
check_logread_errors() {
    log_step "Healthcheck: logread (seit Apply, ${LOGREAD_LINES_BEFORE} Baseline-Zeilen)"
    local total_now skip errors
    total_now="$(logread 2>/dev/null | wc -l)"
    skip="${LOGREAD_LINES_BEFORE:-0}"

    # Neue Zeilen seit Apply auslesen
    errors="$(logread 2>/dev/null | \
        sed -n "$((skip + 1)),\$p" | \
        grep -iE '(hostapd|netifd|wpa_supplicant).*(FAILED|fatal|cannot bind|refused|invalid config|bad key)' | \
        head -20)"

    if [ -n "${errors}" ]; then
        log_fail "Healthcheck: Kritische Fehler im Log seit Apply:"
        echo "${errors}" | while IFS= read -r line; do
            log_fail "  >> ${line}"
        done
        return 1
    fi
    log_ok "Healthcheck: Keine kritischen Log-Fehler seit Apply (${total_now} - ${skip} = $((total_now - skip)) neue Zeilen)"
    return 0
}

check_firewall_zones() {
    [ "${PROFILE}" != "guest_isolated" ] && return 0
    log_step "Healthcheck: Firewall-Zone 'guest'"
    if uci show firewall 2>/dev/null | grep -q "zone_guest"; then
        log_ok "Healthcheck: Firewall-Zone 'guest' konfiguriert"
    else
        log_fail "Healthcheck: Firewall-Zone 'guest' fehlt in UCI"
        return 1
    fi
    return 0
}

run_healthcheck() {
    local fail=0
    check_wireless_up    || fail=1
    check_bridges_up     || fail=1
    check_logread_errors || fail=1   # B10: Hard Fail
    check_firewall_zones || fail=1

    if [ "${fail}" -ne 0 ]; then
        log_fail "Healthcheck fehlgeschlagen - leite Auto-Rollback ein"
        return 1
    fi
    log_ok "Alle Healthchecks bestanden"
    return 0
}

# =============================================================================
# ROLLBACK (B11/B12: metadata-basiert + Post-Rollback-HC + Exit 40)
# =============================================================================
do_rollback() {
    local specific_dir="$1"
    local backup_dir

    if [ -n "${specific_dir}" ] && [ -d "${specific_dir}" ]; then
        backup_dir="${specific_dir}"
    else
        # B11: metadata-basiert, validiert
        backup_dir="$(find_latest_valid_backup "${NODE_ID}" "${ROLLBACK_FROM}")"
    fi

    if [ -z "${backup_dir}" ]; then
        log_fail "Rollback: Kein gültiges Backup für Node ${NODE_ID} gefunden"
        log_fail "Gesuchter Pfad: ${BACKUP_BASE}/*_node${NODE_ID}_*"
        [ -n "${ROLLBACK_FROM}" ] && log_fail "Timestamp-Filter: ${ROLLBACK_FROM}"
        return 1
    fi

    log_step "Rollback: Wiederherstelle aus ${backup_dir}"
    # Metadata anzeigen
    [ -f "${backup_dir}/metadata.json" ] && {
        log_info "Backup-Info: $(cat "${backup_dir}/metadata.json" 2>/dev/null)"
    }

    for cfg in network wireless firewall dhcp; do
        if [ -f "${backup_dir}/${cfg}" ]; then
            if ! cp "${backup_dir}/${cfg}" "/etc/config/${cfg}"; then
                log_fail "Rollback: Konnte /etc/config/${cfg} nicht wiederherstellen"
                return 1
            fi
            log_ok "Rollback: /etc/config/${cfg} OK"
        fi
    done

    log_step "Rollback: Reload nach Wiederherstellung"
    /etc/init.d/network reload >> "${MAIN_LOG}" 2>&1
    sleep 3
    wifi reload >> "${MAIN_LOG}" 2>&1
    sleep "${HEALTHCHECK_SLEEP}"
    /etc/init.d/firewall reload >> "${MAIN_LOG}" 2>&1
    /etc/init.d/dnsmasq restart >> "${MAIN_LOG}" 2>&1

    # B12: Minimaler Post-Rollback-Healthcheck
    log_step "Post-Rollback-Healthcheck"
    local rb_status
    rb_status="$(ubus call network.wireless status 2>/dev/null)"
    if [ -z "${rb_status}" ]; then
        log_fail "Post-Rollback: ubus/WLAN antwortet nicht - kritischer Zustand!"
        log_fail "Manueller Eingriff erforderlich: ssh/console prüfen"
        return 1   # Caller muss Exit 40 auslösen
    fi

    # Prüfe ob mindestens ein Radio aktiv
    if ! echo "${rb_status}" | grep -q '"up":true'; then
        log_fail "Post-Rollback: Kein Radio im Zustand 'up' - WLAN tot!"
        return 1
    fi

    log_ok "Post-Rollback: WLAN-Subsystem OK (mindestens ein Radio up)"
    log_ok "Rollback abgeschlossen: ${backup_dir}"
    return 0
}

# =============================================================================
# UCI DIFF / LOGGING
# =============================================================================
log_uci_diff() {
    log_step "UCI-State bei Fehler:"
    for cfg in wireless network firewall dhcp; do
        echo "--- uci show ${cfg} ---" >> "${STEP_LOG}"
        uci show "${cfg}" >> "${STEP_LOG}" 2>&1
    done
    log_info "Vollständiger UCI-State: ${STEP_LOG}"
}

# =============================================================================
# CLEANUP
# =============================================================================
cleanup() { rm -f "${UCI_BATCH_FILE}" 2>/dev/null; }
trap cleanup EXIT INT TERM

# =============================================================================
# MAIN
# =============================================================================
main() {
    log_init
    parse_args "$@"

    # SELFTEST: sofort, keine weiteren Abhängigkeiten
    [ "${SELFTEST_MODE}" -eq 1 ] && run_selftest

    echo "========================================"
    echo " provision v${VERSION}"
    echo " Node: ${NODE_ID}  Profil: ${PROFILE:-rollback}"
    echo " $(date)"
    echo "========================================"

    log_info "START: node=${NODE_ID} profile=${PROFILE} apply=${DO_APPLY} dry_run=${DRY_RUN} 11r=${ENABLE_11R} 11k=${ENABLE_11K} 11v=${ENABLE_11V} allow_dfs=${ALLOW_DFS}"

    # --- ROLLBACK MODE ---
    if [ "${DO_ROLLBACK}" -eq 1 ]; then
        log_step "Modus: ROLLBACK (from=${ROLLBACK_FROM:-latest})"
        load_master_json
        if ! do_rollback ""; then
            log_fail "Rollback fehlgeschlagen!"
            exit ${EXIT_ROLLBACK}
        fi
        log_ok "Rollback erfolgreich"
        exit ${EXIT_OK}
    fi

    # --- LOAD CONFIG + RADIOS ---
    load_master_json
    detect_radios

    # --- VALIDATE ONLY ---
    if [ "${VALIDATE_ONLY}" -eq 1 ]; then
        run_validations || exit ${EXIT_VALIDATION}
        echo "  Validierung OK (--validate-only)"
        exit ${EXIT_OK}
    fi

    # --- PRE-VALIDATE (Hard Gate) ---
    run_validations || exit ${EXIT_VALIDATION}

    # --- DRY RUN ---
    if [ "${DRY_RUN}" -eq 1 ]; then
        log_step "Modus: DRY-RUN"
        render_profile || exit ${EXIT_VALIDATION}
        echo "--- UCI-Batch (dry-run, kein Commit) ---"
        cat "${UCI_BATCH_FILE}"
        echo "--- Ende DRY-RUN ---"
        exit ${EXIT_OK}
    fi

    # --- APPLY ---
    if [ "${DO_APPLY}" -eq 1 ]; then

        # Hard Gate: Backup muss vollständig sein
        create_backup || {
            log_fail "Backup unvollständig - Apply abgebrochen (Hard Gate)"
            exit ${EXIT_APPLY}
        }

        # Render
        render_profile || {
            log_fail "Render fehlgeschlagen"
            exit ${EXIT_APPLY}
        }

        # Apply
        apply_config || {
            log_fail "Apply fehlgeschlagen"
            log_uci_diff
            log_step "Auto-Rollback nach Apply-Fehler..."
            if ! do_rollback "${BACKUP_DIR}"; then
                log_fail "Auto-Rollback fehlgeschlagen!"
                exit ${EXIT_ROLLBACK}
            fi
            exit ${EXIT_APPLY}
        }

        # Healthcheck (Hard Gate, B10: logread ist jetzt Hard Fail)
        run_healthcheck || {
            log_fail "Healthcheck fehlgeschlagen"
            log_uci_diff
            log_step "Auto-Rollback nach Healthcheck-Fehler..."
            if ! do_rollback "${BACKUP_DIR}"; then
                log_fail "Auto-Rollback fehlgeschlagen!"
                exit ${EXIT_ROLLBACK}
            fi
            exit ${EXIT_HEALTHCHECK}
        }

        log_ok "DONE: node=${NODE_ID} profile=${PROFILE} - Provisioning erfolgreich"
        echo "========================================"
        echo " Provisioning ERFOLGREICH"
        echo " Log: ${STEP_LOG}"
        echo "========================================"
        exit ${EXIT_OK}
    fi
}

main "$@"
