}

# B15: Radio-Erkennung per UCI band, kein hardcoded radio0/radio1
detect_radios() {
    RADIO5G_IDX=""
    RADIO2G_IDX=""
    local i band
    for i in 0 1 2 3; do
        band="$(uci -q get "wireless.radio${i}.band" 2>/dev/null)"
        [ -z "${band}" ] && continue
        case "${band}" in
            5g|5ghz|5GHz|5GHZ)     [ -z "${RADIO5G_IDX}" ] && RADIO5G_IDX="radio${i}" ;;
            2g|2ghz|2.4ghz|2GHz|2GHZ|2.4GHz) [ -z "${RADIO2G_IDX}" ] && RADIO2G_IDX="radio${i}" ;;
        esac
    done

    if [ -z "${RADIO5G_IDX}" ] && [ -z "${RADIO2G_IDX}" ]; then
        log_warn "Keine Radios per UCI erkannt - Fallback: radio0=5G, radio1=2G"
        RADIO5G_IDX="radio0"
        RADIO2G_IDX="radio1"
    else
        [ -z "${RADIO5G_IDX}" ] && { log_warn "Kein 5G-Radio erkannt, Fallback radio0"; RADIO5G_IDX="radio0"; }
        [ -z "${RADIO2G_IDX}" ] && { log_warn "Kein 2G-Radio erkannt, Fallback radio1"; RADIO2G_IDX="radio1"; }
    fi
    log_ok "Radio-Mapping: 5G=${RADIO5G_IDX} 2G=${RADIO2G_IDX}"
}

# =============================================================================
# SELFTEST (B16)
# =============================================================================
run_selftest() {
    local fail=0
    echo "========================================"
    echo " provision v${VERSION} -- SELFTEST"
    echo " $(date)"
    echo "========================================"

    _selftest_check() {
        local label="$1"; local cmd="$2"
        if eval "${cmd}" >/dev/null 2>&1; then
            echo "  [OK]   ${label}"
        else
            echo "  [FAIL] ${label}"
            fail=1
        fi
    }
    _selftest_warn() {
        local label="$1"; local cmd="$2"
        if eval "${cmd}" >/dev/null 2>&1; then
            echo "  [OK]   ${label}"
        else
            echo "  [WARN] ${label} (optional)"
        fi
    }

    echo "--- Tools ---"
    _selftest_check "uci"        "command -v uci"
    _selftest_check "ubus"       "command -v ubus"
    _selftest_check "jsonfilter" "command -v jsonfilter"
    _selftest_check "ip"         "command -v ip"
    _selftest_check "iw"         "command -v iw"
    _selftest_check "logread"    "command -v logread"
    _selftest_check "sha256sum"  "command -v sha256sum"
    _selftest_check "wifi"       "command -v wifi"
    _selftest_warn  "jshn"       "command -v jshn"
    _selftest_warn  "bridge"     "command -v bridge"
    _selftest_check "opkg"       "command -v opkg"

    echo "--- Pakete ---"
    local found_wpad=0
    for pkg in wpad-openssl wpad-full; do
        if opkg list-installed 2>/dev/null | grep -q "^${pkg} "; then
            echo "  [OK]   ${pkg} installiert"
            found_wpad=1
            break
        fi
    done
    [ "${found_wpad}" -eq 0 ] && echo "  [WARN] wpad-openssl/wpad-full nicht installiert"

    if opkg list-installed 2>/dev/null | grep -qE '^wpad(-basic|-mini)'; then
        echo "  [FAIL] wpad-basic/mini installiert (Konflikt mit wpad-openssl)"
        fail=1
    fi

    echo "--- Dateien ---"
    [ -f "${MASTER_JSON}" ] && \
        echo "  [OK]   master.json: ${MASTER_JSON}" || \
        echo "  [WARN] master.json fehlt: ${MASTER_JSON}"
    [ -d "${PROVISION_DIR}" ] && \
        echo "  [OK]   PROVISION_DIR: ${PROVISION_DIR}" || \
        echo "  [INFO] PROVISION_DIR wird beim ersten Run angelegt"

    echo "--- System ---"
    _selftest_check "ubus antwortet"       "ubus list 2>/dev/null | grep -q network"
    _selftest_warn  "Wireless ubus aktiv"  "ubus call network.wireless status 2>/dev/null | grep -q radio"
    _selftest_warn  "Bridge br-lan"        "ip link show br-lan 2>/dev/null | grep -q br-lan"

    echo "========================================"
    if [ "${fail}" -eq 0 ]; then
        echo " SELFTEST: BESTANDEN"
        exit ${EXIT_OK}
    else
        echo " SELFTEST: FEHLGESCHLAGEN - Fix Required"
        exit ${EXIT_VALIDATION}
    fi
}

# =============================================================================
# VALIDIERUNGEN
# =============================================================================

# B01/B02: wpad-basic Konflikt = Hard Fail
validate_packages() {
    log_step "Paket-Validierung (wpad)"
    if ! command -v opkg >/dev/null 2>&1; then
        log_fail "opkg nicht gefunden - Paket-Validierung nicht möglich!"
        log_fail "Ist dies ein OpenWrt-System mit opkg?"
        return 1
    fi
    local found=0
    for pkg in wpad-openssl wpad-full; do
        if opkg list-installed 2>/dev/null | grep -q "^${pkg} "; then
            log_ok "Paket gefunden: ${pkg}"
            found=1
            break
        fi
    done
    if [ "${found}" -eq 0 ]; then
        log_fail "Kein geeignetes wpad-Paket! WPA3/SAE+802.11r erfordern wpad-openssl oder wpad-full."
        log_fail "Fix: opkg update && opkg remove wpad-basic-wolfssl wpad-basic wpad-mini && opkg install wpad-openssl"
        return 1
    fi

    # B02: wpad-basic/mini Konflikt = Hard Fail
    if opkg list-installed 2>/dev/null | grep -qE '^wpad(-basic|-mini)'; then
        log_fail "wpad-basic/mini ist GLEICHZEITIG mit wpad-openssl/full installiert - Paketkonflikt!"
        log_fail "Fix: opkg remove wpad-basic-wolfssl wpad-basic wpad-mini"
        return 1
    fi

    if [ "${PROFILE}" = "mesh_11s_backhaul" ] && [ "${MESH_PROTO}" = "batadv" ]; then
        if ! opkg list-installed 2>/dev/null | grep -q '^kmod-batman-adv '; then
            log_fail "MESH_PROTO=batadv aber kmod-batman-adv nicht installiert!"
            log_fail "Fix: opkg install kmod-batman-adv batctl-full  ODER  MESH_PROTO=none setzen"
            return 1
        fi
        log_ok "kmod-batman-adv: installiert"
    fi
    return 0
}

validate_regdomain() {
    log_step "Regdomain-Validierung"
    local current_reg
    current_reg="$(iw reg get 2>/dev/null | grep '^country' | awk '{print $2}' | tr -d ':')"
    if [ -z "${current_reg}" ]; then
        log_warn "Regdomain nicht lesbar (iw reg get fehlgeschlagen)"
    elif [ "${current_reg}" != "${CFG_REGDOMAIN}" ]; then
        log_warn "Regdomain-Mismatch: aktuell=${current_reg} erwartet=${CFG_REGDOMAIN} - wird per UCI gesetzt"
    else
        log_ok "Regdomain korrekt: ${current_reg}"
    fi
    return 0
}

# B04: DFS-Kanal = Hard Fail (außer --allow-dfs)
validate_channel() {
    log_step "Channel/HTMode-Validierung"
    local iw_out; iw_out="$(iw list 2>/dev/null)"
    [ -z "${iw_out}" ] && { log_warn "iw list leer - WLAN-Treiber bereit?"; return 0; }

    local is_dfs=0
    case "${CFG_RADIO5G_CHANNEL}" in
        52|56|60|64|100|104|108|112|116|120|124|128|132|136|140|144)
            is_dfs=1
            ;;
        36|40|44|48|149|153|157|161|165)
            log_ok "5G-Channel ${CFG_RADIO5G_CHANNEL}: non-DFS"
            ;;
        *)
            log_warn "5G-Channel ${CFG_RADIO5G_CHANNEL}: bitte manuell prüfen"
            ;;
    esac

    if [ "${is_dfs}" -eq 1 ]; then
        if [ "${ALLOW_DFS}" -eq 1 ]; then
            log_warn "5G-Channel ${CFG_RADIO5G_CHANNEL} ist DFS-pflichtig - explizit erlaubt via --allow-dfs"
        else
            log_fail "5G-Channel ${CFG_RADIO5G_CHANNEL} ist DFS-pflichtig (Radar-Detection)!"
            log_fail "Entweder non-DFS Channel in master.json setzen (36/40/44/48)"
            log_fail "oder --allow-dfs Flag verwenden wenn DFS bewusst gewünscht."
            return 1
        fi
    fi

    # B20: noscan nur auf non-DFS
    # (wird in render_radios() berücksichtigt via IS_DFS_CHANNEL)
    # Speichern für render_radios()
    # shellcheck disable=SC2034
    IS_DFS_CHANNEL="${is_dfs}"

    # HTMode Plausibilität
    case "${CFG_RADIO5G_HTMODE}" in
        VHT20|VHT40|VHT80|VHT80+80|VHT160|HE20|HE40|HE80|HE160|EHT80|EHT160|EHT320)
            log_ok "5G HTMode: ${CFG_RADIO5G_HTMODE}" ;;
        *) log_warn "5G HTMode '${CFG_RADIO5G_HTMODE}' unbekannt" ;;
    esac
    case "${CFG_RADIO2G_HTMODE}" in
        HT20|HT40|HE20|HE40) log_ok "2G HTMode: ${CFG_RADIO2G_HTMODE}" ;;
        *) log_warn "2G HTMode '${CFG_RADIO2G_HTMODE}' unbekannt" ;;
    esac
    return 0
}

validate_wireless_status() {
    log_step "WLAN-Status via ubus"
    local status
    status="$(ubus call network.wireless status 2>/dev/null)"
    if [ -z "${status}" ]; then
        log_warn "ubus network.wireless status: keine Antwort (WLAN-Subsystem noch nicht bereit)"
    else
        log_ok "ubus network.wireless status: OK"
        [ "${VERBOSE}" -eq 1 ] && echo "${status}" | head -20
    fi
    return 0
}

# B03/B13: Echte CIDR-Überlappung + VLAN Sub-Device Check
validate_dsa_bridge() {
    log_step "DSA/Bridge/VLAN-Konsistenz-Check"

    # Bridge existiert?
    if ! ip link show type bridge 2>/dev/null | grep -q 'br-lan'; then
        log_fail "Bridge br-lan nicht gefunden - DSA konfiguriert?"
        return 1
    fi
    log_ok "br-lan vorhanden"

    # VLAN-IDs auf Duplikate prüfen
    local v_set=""
    for vlan in "${CFG_VLAN_MGMT}" "${CFG_VLAN_LAN}" "${CFG_VLAN_GUEST}"; do
        if echo "${v_set}" | grep -q ":${vlan}:"; then
            log_fail "VLAN-ID ${vlan} doppelt vergeben in master.json!"
            return 1
        fi
        v_set="${v_set}:${vlan}:"
    done
    log_ok "VLAN-IDs eindeutig: mgmt=${CFG_VLAN_MGMT} lan=${CFG_VLAN_LAN} guest=${CFG_VLAN_GUEST}"

    # B03: Echte CIDR-Subnetz-Überlappung
    local overlap_found=0
    if subnets_overlap "${CFG_IP_MGMT_SUBNET}" "${CFG_IP_LAN_SUBNET}"; then
        log_fail "Subnetz-Überlappung: mgmt=${CFG_IP_MGMT_SUBNET} und lan=${CFG_IP_LAN_SUBNET}"
        overlap_found=1
    fi
    if subnets_overlap "${CFG_IP_MGMT_SUBNET}" "${CFG_IP_GUEST_SUBNET}"; then
        log_fail "Subnetz-Überlappung: mgmt=${CFG_IP_MGMT_SUBNET} und guest=${CFG_IP_GUEST_SUBNET}"
        overlap_found=1
    fi
    if subnets_overlap "${CFG_IP_LAN_SUBNET}" "${CFG_IP_GUEST_SUBNET}"; then
        log_fail "Subnetz-Überlappung: lan=${CFG_IP_LAN_SUBNET} und guest=${CFG_IP_GUEST_SUBNET}"
        overlap_found=1
    fi
    [ "${overlap_found}" -eq 1 ] && return 1
    log_ok "Subnetze kollisionsfrei (CIDR-geprüft)"

    # B13: VLAN Sub-Devices prüfen (br-lan.VLAN muss existieren oder kernel-seitig anlegbar sein)
    # Prüfen ob Kernel VLAN filtering auf br-lan aktiv
    local vlan_filter
    vlan_filter="$(cat /sys/class/net/br-lan/bridge/vlan_filtering 2>/dev/null)"
    if [ "${vlan_filter}" = "1" ]; then
        log_ok "br-lan VLAN-Filtering aktiv"
        # Prüfe ob VLAN Sub-Devices für LAN/MGMT vorhanden oder per netifd angelegt werden
        for vlan in "${CFG_VLAN_LAN}" "${CFG_VLAN_MGMT}"; do
            if ip link show "br-lan.${vlan}" >/dev/null 2>&1; then
                log_ok "br-lan.${vlan} vorhanden"
            else
                log_warn "br-lan.${vlan} noch nicht aktiv (wird nach network reload angelegt)"
            fi
        done
    else
        log_warn "br-lan VLAN-Filtering nicht aktiv - DSA bridge-vlan konfiguriert?"
        log_warn "Nach Apply müssen br-lan.${CFG_VLAN_LAN} und br-lan.${CFG_VLAN_MGMT} entstehen"
    fi

    return 0
}

validate_node_id() {
    log_step "Node-ID Validierung"
    local found; found="$(jf "${MASTER_JSON}" "$.nodes[?(@.id==\"${NODE_ID}\")].id" 2>/dev/null)"
    if [ -z "${found}" ]; then
        log_fail "Node-ID '${NODE_ID}' nicht in master.json!"
        log_fail "Verfügbare Nodes:"
        jf "${MASTER_JSON}" '$.nodes[*].id' 2>/dev/null | tr ' ' '\n' | sed 's/^/  - /'
        return 1
    fi
    [ -z "${CFG_NODE_MGMT_IP}" ] && {
        log_fail "Node ${NODE_ID}: mgmt_ip nicht gesetzt in master.json"
        return 1
    }
    log_ok "Node ${NODE_ID}: hostname=${CFG_NODE_HOSTNAME} mgmt_ip=${CFG_NODE_MGMT_IP}"
    return 0
}

# B05/B06/B07: 802.11r Validierung
validate_11r() {
    [ "${ENABLE_11R}" -eq 0 ] && return 0
    log_step "802.11r Validierung"

    # B05: mobility_domain muss genau 4 Hex-Zeichen sein
    local md="${CFG_MOBILITY_DOMAIN}"
    if [ "${#md}" -ne 4 ]; then
        log_fail "mobility_domain '${md}' ungültig - muss genau 4 Zeichen haben (z.B. 'ab12')"
        return 1
    fi
    # Nur Hex-Zeichen erlaubt
    local md_check; md_check="$(echo "${md}" | tr -d '0-9a-fA-F')"
    if [ -n "${md_check}" ]; then
        log_fail "mobility_domain '${md}' enthält ungültige Zeichen - nur 0-9a-fA-F erlaubt"
        return 1
    fi
    log_ok "mobility_domain: '${md}' (gültig)"

    # B06: r0kh und r1kh müssen vorhanden sein
    local r0kh_count r1kh_count
    r0kh_count=0
    r1kh_count=0
    local i nas_id r1kh_id
    i=0
    while [ $i -le 20 ]; do
        nas_id="$(jf "${MASTER_JSON}" "$.roaming.r0kh[${i}].nas_id" 2>/dev/null)"
        [ -z "${nas_id}" ] && break
        r0kh_count=$((r0kh_count + 1))
        i=$((i + 1))
    done
    i=0
    while [ $i -le 20 ]; do
        r1kh_id="$(jf "${MASTER_JSON}" "$.roaming.r1kh[${i}].r1kh_id" 2>/dev/null)"
        [ -z "${r1kh_id}" ] && break
        r1kh_count=$((r1kh_count + 1))
        i=$((i + 1))
    done

    if [ "${r0kh_count}" -eq 0 ]; then
        log_fail "802.11r aktiv aber roaming.r0kh leer! Für Multi-AP-FT zwingend erforderlich."
        log_fail "Trage r0kh-Einträge (nas_id, ip, key) für alle AP-Nodes in master.json ein."
        return 1
    fi
    if [ "${r1kh_count}" -eq 0 ]; then
        log_fail "802.11r aktiv aber roaming.r1kh leer! Für Multi-AP-FT zwingend erforderlich."
        log_fail "Trage r1kh-Einträge (r1kh_id, addr, key) für alle AP-Nodes in master.json ein."
        return 1
    fi
    log_ok "r0kh: ${r0kh_count} Einträge, r1kh: ${r1kh_count} Einträge"
    return 0
}

run_validations() {
    local fail=0
    validate_packages          || fail=1
    validate_node_id           || fail=1
    validate_regdomain
    validate_channel           || fail=1
    validate_wireless_status
    validate_dsa_bridge        || fail=1
    [ "${ENABLE_11R}" -eq 1 ] && { validate_11r || fail=1; }

    if [ "${fail}" -ne 0 ]; then
        log_fail "Validierung fehlgeschlagen (Exit ${EXIT_VALIDATION}) - Abbruch vor Apply"
        return 1
    fi
    log_ok "Alle Validierungen bestanden"
    return 0
}

# =============================================================================
# BACKUP (B01: Hard Fail bei cp-Fehler; Vollständigkeitsprüfung)
# =============================================================================
create_backup() {
    log_step "Erstelle Backup"
    BACKUP_DIR="${BACKUP_BASE}/${TIMESTAMP}_node${NODE_ID}_${PROFILE}"
    mkdir -p "${BACKUP_DIR}" || {
        log_fail "Backup-Verzeichnis nicht erstellbar: ${BACKUP_DIR}"
        return 1
    }

    local configs="network wireless firewall dhcp"
    local missing=""
    for cfg in ${configs}; do
        if [ -f "/etc/config/${cfg}" ]; then
            if ! cp "/etc/config/${cfg}" "${BACKUP_DIR}/${cfg}"; then
                log_fail "Backup FEHLGESCHLAGEN für: /etc/config/${cfg}"
                missing="${missing} ${cfg}"
            else
                log_info "Backup OK: /etc/config/${cfg}"
            fi
        else
            log_warn "Config-Datei nicht vorhanden (wird übersprungen): /etc/config/${cfg}"
        fi
    done

    # B01: Hard Gate - mindestens network und wireless müssen gesichert sein
    for critical in network wireless; do
        if [ ! -f "${BACKUP_DIR}/${critical}" ]; then
            log_fail "Kritische Backup-Datei fehlt: ${BACKUP_DIR}/${critical}"
            log_fail "Apply abgebrochen - kein vollständiges Backup vorhanden!"
            return 1
        fi
    done

    # Metadata
    cat > "${BACKUP_DIR}/metadata.json" <<EOF
{
  "timestamp": "${TIMESTAMP}",
  "node_id": "${NODE_ID}",
  "profile": "${PROFILE}",
  "hostname": "${CFG_NODE_HOSTNAME}",
  "enable_11r": ${ENABLE_11R},
  "enable_11k": ${ENABLE_11K},
  "enable_11v": ${ENABLE_11V},
  "files": ["network", "wireless", "firewall", "dhcp"],
  "version": "${VERSION}"
}
EOF

    # SHA256-Checksums
    local cksum_file="${BACKUP_DIR}/checksums.sha256"
    : > "${cksum_file}"
    for cfg in network wireless firewall dhcp; do
        [ -f "${BACKUP_DIR}/${cfg}" ] && \
            sha256sum "${BACKUP_DIR}/${cfg}" >> "${cksum_file}"
    done

    log_ok "Backup vollständig: ${BACKUP_DIR}"
    return 0
}

# B11: Letztes gültiges Backup per Metadata (nicht ls|sort|tail)
find_latest_valid_backup() {
    local node="$1"         # NODE_ID
    local ts_filter="$2"    # Optional: spezifischer Timestamp (ROLLBACK_FROM)

    local candidates dir
    candidates="$(ls -1d "${BACKUP_BASE}"/*_node${node}_* 2>/dev/null | sort -r)"

    if [ -z "${candidates}" ]; then
        echo ""
        return 1
    fi

    for dir in ${candidates}; do
        # Bei --rollback-from: spezifischen Timestamp matchen
        if [ -n "${ts_filter}" ]; then
            echo "${dir}" | grep -q "${ts_filter}" || continue
        fi

        # metadata.json muss vorhanden sein
        [ -f "${dir}/metadata.json" ] || continue

        # Kritische Dateien müssen vorhanden sein
        [ -f "${dir}/network" ]   || continue
        [ -f "${dir}/wireless" ]  || continue

        # Checksums prüfen wenn vorhanden
        if [ -f "${dir}/checksums.sha256" ]; then
            if ! (cd "${dir}" && sha256sum -c checksums.sha256 >/dev/null 2>&1); then
                log_warn "Backup ${dir}: Checksum-Fehler - übersprungen"
                continue
            fi
        fi

        echo "${dir}"
        return 0
    done

    echo ""
    return 1
}

# =============================================================================
