#!/bin/ash
# =============================================================================
# provision v3.0 - OpenWrt Router Provisioning System
# Compatible: OpenWrt 22.03+ / ash / DSA / WPA3+SAE / 802.11r
#
# Bugfixes gegenüber v2.0:
#  B01 Hard Gate: Backup-Fehler blockiert Apply (kein "warn and continue")
#  B02 Hard Gate: wpad-basic neben wpad-openssl = Exit 10
#  B03 Echte CIDR-Subnetz-Überlappung (kein 3-Oktet-Hack)
#  B04 DFS-Kanal = Hard Fail (außer --allow-dfs gesetzt)
#  B05 802.11r: mobility_domain Format-Check (genau 4 Hex-Zeichen)
#  B06 802.11r: r0kh/r1kh leer = Hard Fail wenn --enable-11r gesetzt
#  B07 802.11r: nas_identifier wird gesetzt (Hostname-basiert)
#  B08 802.11r: ft_psk_generate_local='0' wenn r0kh/r1kh konfiguriert
#  B09 logread: zeitfensterbasiert (Zeilen seit Apply, nicht tail -200)
#  B10 logread: kritische Treffer = Hard Fail (Exit 30)
#  B11 Rollback: find_latest_valid_backup() metadata+checksum-basiert
#  B12 Rollback: Post-Rollback-Healthcheck; Exit 40 wenn WLAN tot
#  B13 DSA: prüft ob br-lan.VLAN Sub-Device existiert vor Apply
#  B14 Idempotenz: alle betroffenen Configs bereinigt pro Profil
#  B15 Radio-Erkennung: per UCI band (kein hardcoded radio0/radio1)
#  B16 Neu: --selftest Modus prüft alle Voraussetzungen
#  B17 Neu: --allow-dfs Flag für explizite DFS-Freigabe
#  B18 Neu: --rollback-from <timestamp> für spezifisches Backup
#  B19 Reload-Return-Code direkt geprüft (kein tee-Masking)
#  B20 noscan='1' nur auf non-DFS Kanälen
# =============================================================================

# =============================================================================
# CONFIG BLOCK
# =============================================================================
PROVISION_DIR="/etc/provision"
