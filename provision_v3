UCI_BATCH_FILE="/tmp/provision_uci_batch.$$"
HEALTHCHECK_TIMEOUT=30
HEALTHCHECK_SLEEP=5
MESH_PROTO="none"
VERSION="3.0.0"

# =============================================================================
# EXIT CODES
# =============================================================================
EXIT_OK=0
EXIT_VALIDATION=10
EXIT_APPLY=20
EXIT_HEALTHCHECK=30
EXIT_ROLLBACK=40

# =============================================================================
# GLOBALS
# =============================================================================
NODE_ID=""
PROFILE=""
DO_APPLY=0
DRY_RUN=0
VALIDATE_ONLY=0
DO_ROLLBACK=0
SELFTEST_MODE=0
ALLOW_DFS=0
VERBOSE=0
ENABLE_11R=0
ENABLE_11K=0
ENABLE_11V=0
ROLLBACK_FROM=""
TIMESTAMP=""
BACKUP_DIR=""
CHANGES_NETWORK=0
CHANGES_WIRELESS=0
CHANGES_FIREWALL=0
CHANGES_DHCP=0
APPLY_TIME=0
LOGREAD_LINES_BEFORE=0
RADIO5G_IDX=""
RADIO2G_IDX=""

# Config values (set by load_master_json)
CFG_REGDOMAIN="" CFG_COUNTRY=""
CFG_RADIO5G_CHANNEL="" CFG_RADIO5G_HTMODE="" CFG_RADIO5G_TXPOWER="" CFG_RADIO5G_DISABLED=""
CFG_RADIO2G_CHANNEL="" CFG_RADIO2G_HTMODE="" CFG_RADIO2G_TXPOWER="" CFG_RADIO2G_DISABLED=""
CFG_SSID_MAIN="" CFG_SSID_GUEST="" CFG_SSID_MESH=""
CFG_PASS_MAIN="" CFG_PASS_GUEST="" CFG_PASS_MESH=""
CFG_ENC_POLICY="" CFG_MOBILITY_DOMAIN="" CFG_FT_OVER_DS=""
CFG_VLAN_MGMT="" CFG_VLAN_LAN="" CFG_VLAN_GUEST=""
