    CFG_REGDOMAIN="$(jf_str "${MASTER_JSON}" '$.regdomain' 'DE')"
    CFG_COUNTRY="$(jf_str "${MASTER_JSON}" '$.country' 'DE')"

    CFG_RADIO5G_CHANNEL="$(jf_str "${MASTER_JSON}" '$.radios.radio5g.channel' '36')"
    CFG_RADIO5G_HTMODE="$(jf_str "${MASTER_JSON}" '$.radios.radio5g.htmode' 'VHT80')"
    CFG_RADIO5G_TXPOWER="$(jf_str "${MASTER_JSON}" '$.radios.radio5g.txpower' '20')"
