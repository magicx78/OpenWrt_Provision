# =============================================================================
# LOGGING
# =============================================================================
log_init() {
    TIMESTAMP="$(date +%Y%m%d_%H%M%S)"
    mkdir -p "${LOG_DIR}" 2>/dev/null
    STEP_LOG="${LOG_DIR}/${TIMESTAMP}.log"
    touch "${MAIN_LOG}" 2>/dev/null || MAIN_LOG="/tmp/provision.log"
    touch "${STEP_LOG}" 2>/dev/null || STEP_LOG="/tmp/provision_${TIMESTAMP}.log"
}

_log() {
    local level="$1"; shift
    local msg="$*"
    local ts; ts="$(date '+%Y-%m-%d %H:%M:%S')"
    local line="[${ts}] [${level}] node=${NODE_ID:-?} profile=${PROFILE:-?} ${msg}"
    echo "${line}" >> "${MAIN_LOG}"
    echo "${line}" >> "${STEP_LOG}"
    case "${level}" in
        ERROR|FAIL) echo "  [${level}] ${msg}" >&2 ;;
        WARN)       echo "  [WARN]  ${msg}" >&2 ;;
        *)          [ "${VERBOSE}" -eq 1 ] && echo "  [${level}] ${msg}" || true ;;
    esac
}

log_info()  { _log "INFO"  "$*"; }
log_ok()    { _log "OK"    "$*"; }
log_warn()  { _log "WARN"  "$*"; }
log_error() { _log "ERROR" "$*"; }
log_step()  { _log "STEP"  ">>> $*"; echo "==> $*"; }
log_fail()  { _log "FAIL"  "$*"; echo "  [FAIL] $*" >&2; }

# =============================================================================
# USAGE
# =============================================================================
usage() {
    cat <<EOF
provision v${VERSION} - OpenWrt Router Provisioning System

Usage:
  provision --node-id <id> --profile <profile> [options]

Options:
  --node-id <id>            Node-ID z.B. 01..10
  --profile <name>          ap_roaming | mesh_11s_backhaul | client_backhaul | guest_isolated
  --apply                   Konfiguration anwenden
  --dry-run                 Nur UCI-Batch ausgeben, nichts schreiben
  --validate-only           Nur Validierung, kein Apply
  --rollback                Letztes gültiges Backup wiederherstellen
  --rollback-from <ts>      Spezifisches Backup (Timestamp YYYYMMDD_HHMMSS)
  --enable-11r              802.11r Fast BSS Transition (ap_roaming)
  --enable-11k              802.11k Radio Resource Management
  --enable-11v              802.11v BSS Transition Management
  --allow-dfs               DFS-Kanäle explizit erlauben (sonst Exit 10)
  --selftest                Voraussetzungen prüfen, keine Änderungen
  --verbose                 Erweiterte Ausgabe
  --help                    Diese Hilfe

Exit-Codes:
  0   OK
  10  Validation failed
  20  Apply failed
  30  Healthcheck failed (Auto-Rollback ausgeführt)
  40  Rollback failed (manueller Eingriff nötig)

Beispiele:
  provision --node-id 03 --profile ap_roaming --apply --enable-11r --enable-11k
  provision --node-id 05 --profile guest_isolated --dry-run
  provision --node-id 01 --rollback
  provision --node-id 02 --rollback-from 20240315_143022
  provision --selftest
EOF
    exit ${EXIT_OK}
}

# =============================================================================
# ARGUMENT PARSING
# =============================================================================
parse_args() {
    [ $# -eq 0 ] && usage
    while [ $# -gt 0 ]; do
        case "$1" in
            --node-id)        NODE_ID="$2";        shift 2 ;;
            --profile)        PROFILE="$2";        shift 2 ;;
            --apply)          DO_APPLY=1;           shift ;;
            --dry-run)        DRY_RUN=1;            shift ;;
            --validate-only)  VALIDATE_ONLY=1;      shift ;;
            --rollback)       DO_ROLLBACK=1;        shift ;;
            --rollback-from)  DO_ROLLBACK=1; ROLLBACK_FROM="$2"; shift 2 ;;
            --enable-11r)     ENABLE_11R=1;         shift ;;
            --enable-11k)     ENABLE_11K=1;         shift ;;
            --enable-11v)     ENABLE_11V=1;         shift ;;
            --allow-dfs)      ALLOW_DFS=1;          shift ;;
            --selftest)       SELFTEST_MODE=1;      shift ;;
            --verbose)        VERBOSE=1;            shift ;;
            --help|-h)        usage ;;
            *) log_fail "Unbekannter Parameter: $1"; exit ${EXIT_VALIDATION} ;;
        esac
    done

    # Selftest braucht keine weiteren Parameter
    [ "${SELFTEST_MODE}" -eq 1 ] && return 0

    if [ "${DO_ROLLBACK}" -eq 1 ]; then
        [ -z "${NODE_ID}" ] && { log_fail "--node-id erforderlich für --rollback"; exit ${EXIT_VALIDATION}; }
        return 0
    fi

    [ -z "${NODE_ID}" ] && { log_fail "--node-id ist erforderlich"; exit ${EXIT_VALIDATION}; }
    [ -z "${PROFILE}" ] && { log_fail "--profile ist erforderlich"; exit ${EXIT_VALIDATION}; }

    case "${PROFILE}" in
        ap_roaming|mesh_11s_backhaul|client_backhaul|guest_isolated) ;;
        *) log_fail "Unbekanntes Profil: ${PROFILE}"
           exit ${EXIT_VALIDATION} ;;
    esac

    if [ "${DO_APPLY}" -eq 0 ] && [ "${DRY_RUN}" -eq 0 ] && [ "${VALIDATE_ONLY}" -eq 0 ]; then
        log_fail "Modus angeben: --apply, --dry-run oder --validate-only"
        exit ${EXIT_VALIDATION}
    fi
}

# =============================================================================
# JSON PARSING
# =============================================================================
jf() { jsonfilter -i "$1" -e "$2" 2>/dev/null; }

jf_str() {
    local val; val="$(jf "$1" "$2")"
    [ -n "${val}" ] && echo "${val}" || echo "${3:-}"
}

# -----------------------------------------------------------------------------
# CIDR-Subnetz-Überlappungsprüfung (B03)
# Funktioniert in ash ohne Overflow bei /8-/32 Subnets.
# Vergleicht die relevanten Bits des kleineren Präfixes (= weiteres Netz).
# Returns 0 wenn Überlappung, 1 wenn keine Überlappung.
# -----------------------------------------------------------------------------
subnets_overlap() {
    local cidr1="$1" cidr2="$2"

    local addr1 pfx1 addr2 pfx2
    addr1="${cidr1%%/*}"; pfx1="${cidr1##*/}"
    addr2="${cidr2%%/*}"; pfx2="${cidr2##*/}"

    # Validierung (explizites if, kein Operator-Prioritätsfehler)
    if [ -z "${pfx1}" ] || [ -z "${pfx2}" ]; then return 1; fi

    # Kleineres Präfix bestimmt den Vergleichsbereich
    local check_pfx
    if [ "${pfx1}" -le "${pfx2}" ]; then
        check_pfx="${pfx1}"
    else
        check_pfx="${pfx2}"
    fi

    # Oktette parsen (kein Overflow-Risiko: Werte 0-255)
    local a1 b1 c1 d1 a2 b2 c2 d2
    local OIFS="$IFS"; IFS='.'
    # shellcheck disable=SC2086
    set -- ${addr1}; a1=${1:-0} b1=${2:-0} c1=${3:-0} d1=${4:-0}
    # shellcheck disable=SC2086
    set -- ${addr2}; a2=${1:-0} b2=${2:-0} c2=${3:-0} d2=${4:-0}
    IFS="$OIFS"

    # Vollständige Oktett-Vergleiche
    if [ "${check_pfx}" -ge 8  ]; then [ "${a1}" -ne "${a2}" ] && return 1; fi
    if [ "${check_pfx}" -ge 16 ]; then [ "${b1}" -ne "${b2}" ] && return 1; fi
    if [ "${check_pfx}" -ge 24 ]; then [ "${c1}" -ne "${c2}" ] && return 1; fi
    if [ "${check_pfx}" -ge 32 ]; then [ "${d1}" -ne "${d2}" ] && return 1; fi

    # Partieller Oktet-Vergleich (z.B. /20 → Top-4-Bits von 3. Oktet)
    local partial_bits=$(( check_pfx % 8 ))
    if [ "${partial_bits}" -gt 0 ]; then
        local octet_a octet_b
        case $(( check_pfx / 8 )) in
            0) octet_a="${a1}"; octet_b="${a2}" ;;
            1) octet_a="${b1}"; octet_b="${b2}" ;;
            2) octet_a="${c1}"; octet_b="${c2}" ;;
            3) octet_a="${d1}"; octet_b="${d2}" ;;
            *) return 1 ;;
        esac
        local shift=$(( 8 - partial_bits ))
        local octet_mask=$(( 256 - (1 << shift) ))
        local ma=$(( octet_a & octet_mask ))
        local mb=$(( octet_b & octet_mask ))
        [ "${ma}" -ne "${mb}" ] && return 1
    fi

    return 0  # Subnets überlappen sich
}

