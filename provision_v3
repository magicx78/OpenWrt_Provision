# Prefix-Länge → Dotted-Quad Netmask (kein overflow auf 32-bit ash)
prefix_to_mask() {
    local pfx="$1"
    local a=0 b=0 c=0 d=0
    local full=$(( pfx / 8 ))
    local part=$(( pfx % 8 ))
    [ "${full}" -ge 1 ] && a=255
    [ "${full}" -ge 2 ] && b=255
    [ "${full}" -ge 3 ] && c=255
    [ "${full}" -ge 4 ] && d=255
    # Partielles Oktet
    local partial_octet=0
    if [ "${part}" -gt 0 ]; then
        partial_octet=$(( 256 - (1 << (8 - part)) ))
        case "${full}" in
            0) a="${partial_octet}" ;;
            1) b="${partial_octet}" ;;
            2) c="${partial_octet}" ;;
            3) d="${partial_octet}" ;;
        esac
    fi
    echo "${a}.${b}.${c}.${d}"
}

render_network_lan() {
    local lan_addr="${CFG_IP_LAN_SUBNET%%/*}"
    local lan_pfx="${CFG_IP_LAN_SUBNET##*/}"
    local lan_ip; lan_ip="$(echo "${lan_addr}" | sed 's/\.[0-9]*$/\.1/')"
    local lan_mask; lan_mask="$(prefix_to_mask "${lan_pfx}")"

    uci_batch_add "set network.lan=interface"
    uci_batch_add "set network.lan.device='br-lan.${CFG_VLAN_LAN}'"
    uci_batch_add "set network.lan.proto='static'"
