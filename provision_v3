# =============================================================================
# RENDER: r0kh/r1kh (B06/B08: ft_psk_generate_local korrekt setzen)
# =============================================================================
render_r0kh_r1kh() {
    local iface="$1"
    local i=0 nas_id ip key r1kh_id addr
    local r0kh_count=0 r1kh_count=0

    while [ $i -le 20 ]; do
        nas_id="$(jf "${MASTER_JSON}" "$.roaming.r0kh[${i}].nas_id" 2>/dev/null)"
        [ -z "${nas_id}" ] && break
        ip="$(jf "${MASTER_JSON}" "$.roaming.r0kh[${i}].ip")"
        key="$(jf "${MASTER_JSON}" "$.roaming.r0kh[${i}].key")"
        uci_batch_add "list wireless.${iface}.r0kh='${nas_id} ${ip} ${key}'"
        log_info "r0kh[${i}]: ${nas_id} ${ip}"
        r0kh_count=$((r0kh_count + 1))
        i=$((i + 1))
    done

    i=0
    while [ $i -le 20 ]; do
        r1kh_id="$(jf "${MASTER_JSON}" "$.roaming.r1kh[${i}].r1kh_id" 2>/dev/null)"
        [ -z "${r1kh_id}" ] && break
        addr="$(jf "${MASTER_JSON}" "$.roaming.r1kh[${i}].addr")"
        key="$(jf "${MASTER_JSON}" "$.roaming.r1kh[${i}].key")"
        uci_batch_add "list wireless.${iface}.r1kh='${r1kh_id} ${addr} ${key}'"
        log_info "r1kh[${i}]: ${r1kh_id} ${addr}"
        r1kh_count=$((r1kh_count + 1))
        i=$((i + 1))
    done

    # B08: ft_psk_generate_local='0' wenn r0kh/r1kh vorhanden
    # (ft_psk_generate_local='1' wäre falsch für echtes Multi-AP FT-SAE)
    if [ "${r0kh_count}" -gt 0 ] && [ "${r1kh_count}" -gt 0 ]; then
        uci_batch_add "set wireless.${iface}.ft_psk_generate_local='0'"
        log_info "ft_psk_generate_local=0 (r0kh/r1kh vorhanden → zentrales Key-Management)"
    else
        uci_batch_add "set wireless.${iface}.ft_psk_generate_local='1'"
        log_warn "Kein r0kh/r1kh → ft_psk_generate_local=1 (Single-AP oder lokal)"
    fi
}

# =============================================================================
# RENDER: Profil ap_roaming
# =============================================================================
render_ap_roaming() {
    log_step "Render: Profil ap_roaming"
    CHANGES_WIRELESS=1; CHANGES_NETWORK=1

    local enc="${CFG_ENC_POLICY}"
    [ "${enc}" != "sae" ] && [ "${enc}" != "sae-mixed" ] && enc="sae"

    # B14: alle betroffenen Configs bereinigen
    uci_delete_managed_sections "wireless"
    uci_delete_managed_sections "network"

    # 5G AP
    uci_batch_add "set wireless.wlan_ap5g=wifi-iface"
    uci_batch_add "set wireless.wlan_ap5g.device='${RADIO5G_IDX}'"
    uci_batch_add "set wireless.wlan_ap5g.mode='ap'"
    uci_batch_add "set wireless.wlan_ap5g.ssid='${CFG_SSID_MAIN}'"
    uci_batch_add "set wireless.wlan_ap5g.encryption='${enc}'"
    uci_batch_add "set wireless.wlan_ap5g.key='${CFG_PASS_MAIN}'"
    uci_batch_add "set wireless.wlan_ap5g.network='lan'"
    uci_batch_add "set wireless.wlan_ap5g.ieee80211w='2'"
    uci_batch_add "set wireless.wlan_ap5g.sae_pwe='2'"
    uci_batch_add "set wireless.wlan_ap5g.sae_require_mfp='1'"
    uci_batch_add "set wireless.wlan_ap5g.${MANAGED_MARKER}='1'"

    # 802.11r
    if [ "${ENABLE_11R}" -eq 1 ]; then
        log_info "802.11r (FT) aktivieren"
        uci_batch_add "set wireless.wlan_ap5g.ieee80211r='1'"
        uci_batch_add "set wireless.wlan_ap5g.mobility_domain='${CFG_MOBILITY_DOMAIN}'"
        uci_batch_add "set wireless.wlan_ap5g.ft_over_ds='${CFG_FT_OVER_DS}'"
        uci_batch_add "set wireless.wlan_ap5g.reassociation_deadline='1000'"
        # B07: NAS-ID setzen (muss mit r0kh-Einträgen übereinstimmen)
        uci_batch_add "set wireless.wlan_ap5g.nas_identifier='${CFG_NODE_HOSTNAME}'"
        render_r0kh_r1kh "wlan_ap5g"
    fi

    # 802.11k
    if [ "${ENABLE_11K}" -eq 1 ]; then
        uci_batch_add "set wireless.wlan_ap5g.ieee80211k='1'"
        uci_batch_add "set wireless.wlan_ap5g.rrm_neighbor_report='1'"
        uci_batch_add "set wireless.wlan_ap5g.rrm_beacon_report='1'"
    fi

    # 802.11v
    if [ "${ENABLE_11V}" -eq 1 ]; then
        uci_batch_add "set wireless.wlan_ap5g.ieee80211v='1'"
        uci_batch_add "set wireless.wlan_ap5g.bss_transition='1'"
        uci_batch_add "set wireless.wlan_ap5g.wnm_sleep_mode='0'"
    fi

    # 2G AP
    uci_batch_add "set wireless.wlan_ap2g=wifi-iface"
    uci_batch_add "set wireless.wlan_ap2g.device='${RADIO2G_IDX}'"
    uci_batch_add "set wireless.wlan_ap2g.mode='ap'"
    uci_batch_add "set wireless.wlan_ap2g.ssid='${CFG_SSID_MAIN}'"
    uci_batch_add "set wireless.wlan_ap2g.encryption='${enc}'"
    uci_batch_add "set wireless.wlan_ap2g.key='${CFG_PASS_MAIN}'"
    uci_batch_add "set wireless.wlan_ap2g.network='lan'"
    uci_batch_add "set wireless.wlan_ap2g.ieee80211w='2'"
    uci_batch_add "set wireless.wlan_ap2g.sae_pwe='2'"
    uci_batch_add "set wireless.wlan_ap2g.${MANAGED_MARKER}='1'"
    [ "${ENABLE_11K}" -eq 1 ] && uci_batch_add "set wireless.wlan_ap2g.ieee80211k='1'"
    [ "${ENABLE_11V}" -eq 1 ] && uci_batch_add "set wireless.wlan_ap2g.bss_transition='1'"

    render_network_lan
    log_ok "Profil ap_roaming gerendert"
}

