#!/bin/ash
# =============================================================================
# provision - OpenWrt Router Provisioning System
# Version: 2.0.0
# Compatible: OpenWrt 22.03+ / ash / DSA / WPA3+SAE / 802.11r
# =============================================================================

# =============================================================================
# CONFIG BLOCK - alle Defaults hier anpassen
# =============================================================================
PROVISION_DIR="/etc/provision"
MASTER_JSON="${PROVISION_DIR}/master.json"
BACKUP_BASE="${PROVISION_DIR}/backups"
LOG_DIR="${PROVISION_DIR}/logs"
MAIN_LOG="/var/log/provision.log"
MANAGED_MARKER="provision_managed"
UCI_BATCH_FILE="/tmp/provision_uci_batch.$$"
HEALTHCHECK_TIMEOUT=30
HEALTHCHECK_SLEEP=5
LOGREAD_WINDOW=60   # Sekunden rückblickend nach Apply
MIN_WPAD="wpad-openssl wpad-full"
# Arbeitsannahme: MESH_PROTO=none = reines 802.11s-Bridging (kein batman-adv).
# Auf 'batadv' setzen wenn kmod-batman-adv installiert ist.
MESH_PROTO="none"
VERSION="2.0.0"

# =============================================================================
# EXIT CODES
# =============================================================================
EXIT_OK=0
EXIT_VALIDATION=10
EXIT_APPLY=20
EXIT_HEALTHCHECK=30
EXIT_ROLLBACK=40

# =============================================================================
# GLOBALS (werden zur Laufzeit gesetzt)
# =============================================================================
NODE_ID=""
PROFILE=""
DO_APPLY=0
DRY_RUN=0
VALIDATE_ONLY=0
DO_ROLLBACK=0
VERBOSE=0
ENABLE_11R=0
ENABLE_11K=0
ENABLE_11V=0
TIMESTAMP=""
BACKUP_DIR=""
CHANGES_NETWORK=0
CHANGES_WIRELESS=0
CHANGES_FIREWALL=0
CHANGES_DHCP=0
APPLY_TIME=0

# =============================================================================
# LOGGING
# =============================================================================
log_init() {
    TIMESTAMP="$(date +%Y%m%d_%H%M%S)"
    mkdir -p "${LOG_DIR}" 2>/dev/null
    STEP_LOG="${LOG_DIR}/${TIMESTAMP}.log"
    touch "${MAIN_LOG}" 2>/dev/null || MAIN_LOG="/tmp/provision.log"
    touch "${STEP_LOG}" 2>/dev/null || STEP_LOG="/tmp/provision_${TIMESTAMP}.log"
}

_log() {
    local level="$1"; shift
    local msg="$*"
    local ts; ts="$(date '+%Y-%m-%d %H:%M:%S')"
    local line="[${ts}] [${level}] node=${NODE_ID:-?} profile=${PROFILE:-?} ${msg}"
    echo "${line}" >> "${MAIN_LOG}"
    echo "${line}" >> "${STEP_LOG}"
    case "${level}" in
        ERROR|FAIL) echo "  [${level}] ${msg}" >&2 ;;
        WARN)       echo "  [WARN]  ${msg}" >&2 ;;
        *)          [ "${VERBOSE}" -eq 1 ] && echo "  [${level}] ${msg}" || true ;;
    esac
}

log_info()  { _log "INFO"  "$*"; }
log_ok()    { _log "OK"    "$*"; }
log_warn()  { _log "WARN"  "$*"; }
log_error() { _log "ERROR" "$*"; }
log_step()  { _log "STEP"  ">>> $*"; echo "==> $*"; }
log_fail()  { _log "FAIL"  "$*"; echo "  [FAIL] $*" >&2; }

# =============================================================================
# USAGE
# =============================================================================
usage() {
    cat <<EOF
provision v${VERSION} - OpenWrt Router Provisioning System

Usage:
  provision --node-id <id> --profile <profile> [options]

Options:
  --node-id <id>       Node-ID z.B. 01..10
  --profile <name>     ap_roaming | mesh_11s_backhaul | client_backhaul | guest_isolated
  --apply              Konfiguration anwenden
  --dry-run            Nur UCI-Batch ausgeben, nichts schreiben
  --validate-only      Nur Validierung, kein Apply
  --rollback           Letztes Backup wiederherstellen
  --enable-11r         802.11r Fast BSS Transition aktivieren (ap_roaming)
  --enable-11k         802.11k Radio Resource Management (ap_roaming)
  --enable-11v         802.11v BSS Transition Management (ap_roaming)
  --verbose            Erweiterte Ausgabe
  --help               Diese Hilfe

Exit-Codes:
  0   OK
  10  Validation failed
  20  Apply failed
  30  Healthcheck failed
  40  Rollback failed

Beispiele:
  provision --node-id 03 --profile ap_roaming --apply --enable-11r --enable-11k
  provision --node-id 05 --profile guest_isolated --dry-run
  provision --node-id 01 --profile mesh_11s_backhaul --validate-only
  provision --node-id 03 --rollback
EOF
    exit ${EXIT_OK}
}

# =============================================================================
# ARGUMENT PARSING
# =============================================================================
parse_args() {
    [ $# -eq 0 ] && usage
    while [ $# -gt 0 ]; do
        case "$1" in
            --node-id)       NODE_ID="$2";   shift 2 ;;
            --profile)       PROFILE="$2";   shift 2 ;;
            --apply)         DO_APPLY=1;      shift ;;
            --dry-run)       DRY_RUN=1;       shift ;;
            --validate-only) VALIDATE_ONLY=1; shift ;;
            --rollback)      DO_ROLLBACK=1;   shift ;;
            --enable-11r)    ENABLE_11R=1;    shift ;;
            --enable-11k)    ENABLE_11K=1;    shift ;;
            --enable-11v)    ENABLE_11V=1;    shift ;;
            --verbose)       VERBOSE=1;       shift ;;
            --help|-h)       usage ;;
            *) log_fail "Unbekannter Parameter: $1"; exit ${EXIT_VALIDATION} ;;
        esac
    done

    if [ "${DO_ROLLBACK}" -eq 1 ]; then
        [ -z "${NODE_ID}" ] && { log_fail "--node-id erforderlich für --rollback"; exit ${EXIT_VALIDATION}; }
        return 0
    fi

    [ -z "${NODE_ID}" ]  && { log_fail "--node-id ist erforderlich";  exit ${EXIT_VALIDATION}; }
    [ -z "${PROFILE}" ]  && { log_fail "--profile ist erforderlich";  exit ${EXIT_VALIDATION}; }

    case "${PROFILE}" in
        ap_roaming|mesh_11s_backhaul|client_backhaul|guest_isolated) ;;
        *) log_fail "Unbekanntes Profil: ${PROFILE}. Erlaubt: ap_roaming mesh_11s_backhaul client_backhaul guest_isolated"
           exit ${EXIT_VALIDATION} ;;
    esac

    if [ "${DO_APPLY}" -eq 0 ] && [ "${DRY_RUN}" -eq 0 ] && [ "${VALIDATE_ONLY}" -eq 0 ]; then
        log_fail "Modus angeben: --apply, --dry-run oder --validate-only"
        exit ${EXIT_VALIDATION}
    fi
}

# =============================================================================
# JSON PARSING (jsonfilter / jshn - OpenWrt native)
# =============================================================================
jf() {
    # jsonfilter wrapper: jf <file> <expression>
    jsonfilter -i "$1" -e "$2" 2>/dev/null
}

jf_str() {
    local val; val="$(jf "$1" "$2")"
    [ -n "${val}" ] && echo "${val}" || echo "${3:-}"
}

# jshn-basiertes Laden der Master-Config in Shell-Variablen
load_master_json() {
    log_step "Lade master.json: ${MASTER_JSON}"
    [ -f "${MASTER_JSON}" ] || {
        log_fail "master.json nicht gefunden: ${MASTER_JSON}"
        exit ${EXIT_VALIDATION}
    }

    # Globale Felder
    CFG_REGDOMAIN="$(jf_str "${MASTER_JSON}" '$.regdomain' 'DE')"
    CFG_COUNTRY="$(jf_str "${MASTER_JSON}" '$.country' 'DE')"

    # Radio 5G
    CFG_RADIO5G_CHANNEL="$(jf_str "${MASTER_JSON}" '$.radios.radio5g.channel' '36')"
    CFG_RADIO5G_HTMODE="$(jf_str "${MASTER_JSON}" '$.radios.radio5g.htmode' 'VHT80')"
    CFG_RADIO5G_TXPOWER="$(jf_str "${MASTER_JSON}" '$.radios.radio5g.txpower' '20')"
    CFG_RADIO5G_DISABLED="$(jf_str "${MASTER_JSON}" '$.radios.radio5g.disabled' '0')"

    # Radio 2G
    CFG_RADIO2G_CHANNEL="$(jf_str "${MASTER_JSON}" '$.radios.radio2g.channel' '6')"
    CFG_RADIO2G_HTMODE="$(jf_str "${MASTER_JSON}" '$.radios.radio2g.htmode' 'HT20')"
    CFG_RADIO2G_TXPOWER="$(jf_str "${MASTER_JSON}" '$.radios.radio2g.txpower' '20')"
    CFG_RADIO2G_DISABLED="$(jf_str "${MASTER_JSON}" '$.radios.radio2g.disabled' '0')"

    # SSIDs + Passphrases
    CFG_SSID_MAIN="$(jf_str "${MASTER_JSON}" '$.ssids.main' 'HomeNetwork')"
    CFG_SSID_GUEST="$(jf_str "${MASTER_JSON}" '$.ssids.guest' 'HomeGuest')"
    CFG_SSID_MESH="$(jf_str "${MASTER_JSON}" '$.ssids.mesh' 'mesh_backhaul')"

    CFG_PASS_MAIN="$(jf_str "${MASTER_JSON}" '$.passphrases.main' 'ChangeMe123!')"
    CFG_PASS_GUEST="$(jf_str "${MASTER_JSON}" '$.passphrases.guest' 'GuestPass123!')"
    CFG_PASS_MESH="$(jf_str "${MASTER_JSON}" '$.passphrases.mesh' 'MeshSecret123!')"

    # Encryption policy
    CFG_ENC_POLICY="$(jf_str "${MASTER_JSON}" '$.encryption_policy' 'sae')"
    CFG_MOBILITY_DOMAIN="$(jf_str "${MASTER_JSON}" '$.roaming.mobility_domain' 'abcd')"
    CFG_FT_OVER_DS="$(jf_str "${MASTER_JSON}" '$.roaming.ft_over_ds' '1')"

    # VLANs
    CFG_VLAN_MGMT="$(jf_str "${MASTER_JSON}" '$.vlans.mgmt' '10')"
    CFG_VLAN_LAN="$(jf_str "${MASTER_JSON}" '$.vlans.lan' '20')"
    CFG_VLAN_GUEST="$(jf_str "${MASTER_JSON}" '$.vlans.guest' '30')"

    # IP Plan
    CFG_IP_MGMT_SUBNET="$(jf_str "${MASTER_JSON}" '$.ip_plan.mgmt_subnet' '10.0.10.0/24')"
    CFG_IP_LAN_SUBNET="$(jf_str "${MASTER_JSON}" '$.ip_plan.lan_subnet' '192.168.1.0/24')"
    CFG_IP_GUEST_SUBNET="$(jf_str "${MASTER_JSON}" '$.ip_plan.guest_subnet' '192.168.30.0/24')"
    CFG_DNS_PRIMARY="$(jf_str "${MASTER_JSON}" '$.ip_plan.dns_primary' '1.1.1.1')"
    CFG_DNS_SECONDARY="$(jf_str "${MASTER_JSON}" '$.ip_plan.dns_secondary' '8.8.8.8')"

    # Node-spezifische Felder
    local node_path="$.nodes[?(@.id==\"${NODE_ID}\")]"
    CFG_NODE_HOSTNAME="$(jf_str "${MASTER_JSON}" "${node_path}.hostname" "openwrt-${NODE_ID}")"
    CFG_NODE_MGMT_IP="$(jf_str "${MASTER_JSON}" "${node_path}.mgmt_ip" "")"
    CFG_NODE_ROLE="$(jf_str "${MASTER_JSON}" "${node_path}.role" "${PROFILE}")"
    CFG_NODE_MASTER_AP="$(jf_str "${MASTER_JSON}" "${node_path}.master_ap_ip" "")"

    # Master-AP Info (für client_backhaul)
    CFG_MASTER_AP_BSSID="$(jf_str "${MASTER_JSON}" "${node_path}.master_ap_bssid" "")"

    log_ok "master.json geladen: node=${NODE_ID} hostname=${CFG_NODE_HOSTNAME} mgmt_ip=${CFG_NODE_MGMT_IP}"
}

# =============================================================================
# PRE-VALIDATION
# =============================================================================

validate_packages() {
    log_step "Paket-Validierung (wpad)"
    local found=0
    for pkg in wpad-openssl wpad-full; do
        if opkg list-installed 2>/dev/null | grep -q "^${pkg} "; then
            log_ok "Paket gefunden: ${pkg}"
            found=1
            break
        fi
    done
    if [ "${found}" -eq 0 ]; then
        log_fail "Kein geeignetes wpad-Paket installiert!"
        log_fail "WPA3/SAE und 802.11r erfordern wpad-openssl oder wpad-full."
        log_fail "Behebung:"
        log_fail "  opkg update"
        log_fail "  opkg remove wpad-basic-wolfssl wpad-basic wpad-mini"
        log_fail "  opkg install wpad-openssl"
        return 1
    fi

    # Prüfe ob wpad-basic (inkompatibel) noch da ist
    if opkg list-installed 2>/dev/null | grep -qE '^wpad-basic'; then
        log_warn "wpad-basic noch installiert - Konflikt möglich! Entfernen empfohlen:"
        log_warn "  opkg remove wpad-basic-wolfssl wpad-basic"
    fi

    # batman-adv nur prüfen wenn mesh_11s_backhaul + MESH_PROTO=batadv
    if [ "${PROFILE}" = "mesh_11s_backhaul" ] && [ "${MESH_PROTO}" = "batadv" ]; then
        if ! opkg list-installed 2>/dev/null | grep -q '^kmod-batman-adv '; then
            log_fail "MESH_PROTO=batadv aber kmod-batman-adv nicht installiert!"
            log_fail "Behebung: opkg update && opkg install kmod-batman-adv batctl-full"
            log_fail "Alternativ: MESH_PROTO=none für reines 802.11s-Bridging (kein batadv nötig)"
            return 1
        fi
        log_ok "kmod-batman-adv: installiert"
    fi
    return 0
}

validate_regdomain() {
    log_step "Regdomain-Validierung"
    local current_reg
    current_reg="$(iw reg get 2>/dev/null | grep '^country' | awk '{print $2}' | tr -d ':')"
    if [ -z "${current_reg}" ]; then
        log_warn "Regdomain nicht lesbar (iw reg get fehlgeschlagen)"
    elif [ "${current_reg}" != "${CFG_REGDOMAIN}" ]; then
        log_warn "Regdomain-Mismatch: aktuell=${current_reg} erwartet=${CFG_REGDOMAIN}"
        log_warn "Wird per UCI gesetzt: option country '${CFG_REGDOMAIN}'"
    else
        log_ok "Regdomain korrekt: ${current_reg}"
    fi
    return 0
}

validate_channel() {
    log_step "Channel/HTMode-Validierung via iw list"
    local iw_out; iw_out="$(iw list 2>/dev/null)"
    if [ -z "${iw_out}" ]; then
        log_warn "iw list liefert keine Ausgabe - WLAN-Treiber bereit?"
        return 0
    fi

    # DFS-Warnung für 5G
    case "${CFG_RADIO5G_CHANNEL}" in
        52|56|60|64|100|104|108|112|116|120|124|128|132|136|140|144)
            log_warn "5G-Channel ${CFG_RADIO5G_CHANNEL} ist DFS-pflichtig (Radar-Detection erforderlich)."
            log_warn "Empfehlung: UNII-1 Channels 36/40/44/48 für Mesh/AP nutzen."
            ;;
        36|40|44|48)
            log_ok "5G-Channel ${CFG_RADIO5G_CHANNEL}: UNII-1, kein DFS erforderlich."
            ;;
        *)
            log_warn "5G-Channel ${CFG_RADIO5G_CHANNEL}: bitte manuell prüfen."
            ;;
    esac

    # HTMode Plausibilität
    case "${CFG_RADIO5G_HTMODE}" in
        VHT20|VHT40|VHT80|VHT80+80|VHT160|HE20|HE40|HE80|HE160) log_ok "5G HTMode: ${CFG_RADIO5G_HTMODE} gültig" ;;
        *) log_warn "5G HTMode '${CFG_RADIO5G_HTMODE}' unbekannt - bitte prüfen" ;;
    esac
    case "${CFG_RADIO2G_HTMODE}" in
        HT20|HT40|HE20|HE40) log_ok "2G HTMode: ${CFG_RADIO2G_HTMODE} gültig" ;;
        *) log_warn "2G HTMode '${CFG_RADIO2G_HTMODE}' unbekannt - bitte prüfen" ;;
    esac
    return 0
}

validate_wireless_status() {
    log_step "WLAN-Status via ubus"
    local status
    status="$(ubus call network.wireless status 2>/dev/null)"
    if [ -z "${status}" ]; then
        log_warn "ubus call network.wireless status: keine Antwort (WLAN-Subsystem noch nicht bereit)"
    else
        log_ok "ubus network.wireless status: OK"
        [ "${VERBOSE}" -eq 1 ] && echo "${status}" | head -20
    fi
    return 0
}

validate_dsa_bridge() {
    log_step "DSA/Bridge-Konsistenz-Check"
    # Bridge br-lan muss existieren
    if ! ip link show type bridge 2>/dev/null | grep -q 'br-'; then
        log_warn "Keine Bridge-Interfaces gefunden - DSA korrekt konfiguriert?"
    else
        log_ok "Bridge-Interfaces vorhanden"
    fi

    # VLAN-IDs auf Konsistenz
    local v_set=""
    for vlan in "${CFG_VLAN_MGMT}" "${CFG_VLAN_LAN}" "${CFG_VLAN_GUEST}"; do
        if echo "${v_set}" | grep -q ":${vlan}:"; then
            log_fail "VLAN-ID ${vlan} doppelt vergeben in master.json!"
            return 1
        fi
        v_set="${v_set}:${vlan}:"
    done
    log_ok "VLAN-IDs konsistent: mgmt=${CFG_VLAN_MGMT} lan=${CFG_VLAN_LAN} guest=${CFG_VLAN_GUEST}"

    # Subnetz-Kollisionsprüfung (vereinfacht: erste 3 Oktette)
    local mgmt_prefix; mgmt_prefix="$(echo "${CFG_IP_MGMT_SUBNET}" | cut -d'.' -f1-3)"
    local lan_prefix;  lan_prefix="$(echo "${CFG_IP_LAN_SUBNET}"  | cut -d'.' -f1-3)"
    local guest_prefix; guest_prefix="$(echo "${CFG_IP_GUEST_SUBNET}" | cut -d'.' -f1-3)"

    if [ "${mgmt_prefix}" = "${lan_prefix}" ] || [ "${mgmt_prefix}" = "${guest_prefix}" ] || [ "${lan_prefix}" = "${guest_prefix}" ]; then
        log_fail "Subnetz-Kollision! mgmt=${CFG_IP_MGMT_SUBNET} lan=${CFG_IP_LAN_SUBNET} guest=${CFG_IP_GUEST_SUBNET}"
        return 1
    fi
    log_ok "Subnetze kollisionsfrei"
    return 0
}

validate_node_id() {
    log_step "Node-ID Validierung"
    local found; found="$(jf "${MASTER_JSON}" "$.nodes[?(@.id==\"${NODE_ID}\")].id" 2>/dev/null)"
    if [ -z "${found}" ]; then
        log_fail "Node-ID '${NODE_ID}' nicht in master.json gefunden!"
        log_fail "Verfügbare Nodes:"
        jf "${MASTER_JSON}" '$.nodes[*].id' 2>/dev/null | tr ' ' '\n' | sed 's/^/  - /'
        return 1
    fi
    [ -z "${CFG_NODE_MGMT_IP}" ] && {
        log_fail "Node ${NODE_ID}: mgmt_ip nicht gesetzt in master.json"
        return 1
    }
    log_ok "Node ${NODE_ID}: hostname=${CFG_NODE_HOSTNAME} mgmt_ip=${CFG_NODE_MGMT_IP}"
    return 0
}

run_validations() {
    local fail=0
    validate_packages  || fail=1
    validate_node_id   || fail=1
    validate_regdomain
    validate_channel
    validate_wireless_status
    validate_dsa_bridge || fail=1

    if [ "${fail}" -ne 0 ]; then
        log_fail "Validierung fehlgeschlagen - Abbruch"
        return 1
    fi
    log_ok "Alle Validierungen bestanden"
    return 0
}

# =============================================================================
# BACKUP
# =============================================================================
create_backup() {
    log_step "Erstelle Backup"
    BACKUP_DIR="${BACKUP_BASE}/${TIMESTAMP}_node${NODE_ID}_${PROFILE}"
    mkdir -p "${BACKUP_DIR}" || {
        log_fail "Backup-Verzeichnis konnte nicht erstellt werden: ${BACKUP_DIR}"
        return 1
    }

    local configs="network wireless firewall dhcp"
    for cfg in ${configs}; do
        if [ -f "/etc/config/${cfg}" ]; then
            cp "/etc/config/${cfg}" "${BACKUP_DIR}/${cfg}" && \
                log_info "Backup: /etc/config/${cfg} -> ${BACKUP_DIR}/${cfg}" || \
                log_warn "Backup fehlgeschlagen für: ${cfg}"
        fi
    done

    # Metadata
    cat > "${BACKUP_DIR}/metadata.json" <<EOF
{
  "timestamp": "${TIMESTAMP}",
  "node_id": "${NODE_ID}",
  "profile": "${PROFILE}",
  "hostname": "${CFG_NODE_HOSTNAME}",
  "enable_11r": ${ENABLE_11R},
  "enable_11k": ${ENABLE_11K},
  "enable_11v": ${ENABLE_11V},
  "files": ["network", "wireless", "firewall", "dhcp"]
}
EOF

    # SHA256-Checksums
    for cfg in network wireless firewall dhcp; do
        [ -f "${BACKUP_DIR}/${cfg}" ] && \
            sha256sum "${BACKUP_DIR}/${cfg}" >> "${BACKUP_DIR}/checksums.sha256"
    done

    log_ok "Backup erstellt: ${BACKUP_DIR}"
    return 0
}

# =============================================================================
# UCI BATCH HELPERS
# =============================================================================
uci_batch_init() {
    > "${UCI_BATCH_FILE}"
}

uci_batch_add() {
    echo "$*" >> "${UCI_BATCH_FILE}"
}

# Lösche alle provision_managed Sections einer config
uci_delete_managed_sections() {
    local config="$1"
    # Finde alle sections mit option provision_managed '1'
    local sections
    sections="$(uci show "${config}" 2>/dev/null | grep "\.${MANAGED_MARKER}='1'" | cut -d'.' -f1-2)"
    for sec in ${sections}; do
        uci_batch_add "delete ${sec}"
        log_info "Idempotenz: lösche managed section ${sec}"
    done
}

# uci_batch_commit() entfernt (war dead code, PIPESTATUS-Bug).
# apply_config() führt uci batch direkt aus.

# =============================================================================
# RENDER: System/Hostname
# =============================================================================
render_system() {
    log_step "Render: system"
    uci_batch_add "set system.@system[0].hostname='${CFG_NODE_HOSTNAME}'"
    uci_batch_add "set system.@system[0].timezone='CET-1CEST,M3.5.0,M10.5.0/3'"
    uci_batch_add "set system.@system[0].log_proto='udp'"
    uci_batch_add "commit system"
    log_ok "system section gerendert"
}

# =============================================================================
# RENDER: Radio
# =============================================================================
render_radios() {
    log_step "Render: wireless radios"
    uci_batch_add "set wireless.radio0.country='${CFG_REGDOMAIN}'"
    uci_batch_add "set wireless.radio0.channel='${CFG_RADIO5G_CHANNEL}'"
    uci_batch_add "set wireless.radio0.htmode='${CFG_RADIO5G_HTMODE}'"
    uci_batch_add "set wireless.radio0.txpower='${CFG_RADIO5G_TXPOWER}'"
    uci_batch_add "set wireless.radio0.disabled='${CFG_RADIO5G_DISABLED}'"
    uci_batch_add "set wireless.radio0.noscan='1'"

    uci_batch_add "set wireless.radio1.country='${CFG_REGDOMAIN}'"
    uci_batch_add "set wireless.radio1.channel='${CFG_RADIO2G_CHANNEL}'"
    uci_batch_add "set wireless.radio1.htmode='${CFG_RADIO2G_HTMODE}'"
    uci_batch_add "set wireless.radio1.txpower='${CFG_RADIO2G_TXPOWER}'"
    uci_batch_add "set wireless.radio1.disabled='${CFG_RADIO2G_DISABLED}'"
}

# =============================================================================
# RENDER: Profil ap_roaming
# =============================================================================
render_ap_roaming() {
    log_step "Render: Profil ap_roaming"
    CHANGES_WIRELESS=1
    CHANGES_NETWORK=1

    local enc="${CFG_ENC_POLICY}"
    # Encryption: sae = WPA3-only, sae-mixed = WPA2/WPA3 transition
    [ "${enc}" != "sae" ] && [ "${enc}" != "sae-mixed" ] && enc="sae"

    # Idempotenz: alte managed sections entfernen
    uci_delete_managed_sections "wireless"

    # 5G AP
    uci_batch_add "set wireless.wlan_ap5g=wifi-iface"
    uci_batch_add "set wireless.wlan_ap5g.device='radio0'"
    uci_batch_add "set wireless.wlan_ap5g.mode='ap'"
    uci_batch_add "set wireless.wlan_ap5g.ssid='${CFG_SSID_MAIN}'"
    uci_batch_add "set wireless.wlan_ap5g.encryption='${enc}'"
    uci_batch_add "set wireless.wlan_ap5g.key='${CFG_PASS_MAIN}'"
    uci_batch_add "set wireless.wlan_ap5g.network='lan'"
    uci_batch_add "set wireless.wlan_ap5g.ieee80211w='2'"
    uci_batch_add "set wireless.wlan_ap5g.${MANAGED_MARKER}='1'"

    # SAE-specific
    uci_batch_add "set wireless.wlan_ap5g.sae_pwe='2'"
    uci_batch_add "set wireless.wlan_ap5g.sae_require_mfp='1'"

    # 802.11r
    if [ "${ENABLE_11R}" -eq 1 ]; then
        log_info "802.11r (FT) aktivieren"
        uci_batch_add "set wireless.wlan_ap5g.ieee80211r='1'"
        uci_batch_add "set wireless.wlan_ap5g.mobility_domain='${CFG_MOBILITY_DOMAIN}'"
        uci_batch_add "set wireless.wlan_ap5g.ft_over_ds='${CFG_FT_OVER_DS}'"
        uci_batch_add "set wireless.wlan_ap5g.ft_psk_generate_local='1'"
        uci_batch_add "set wireless.wlan_ap5g.reassociation_deadline='1000'"
    fi

    # 802.11k
    if [ "${ENABLE_11K}" -eq 1 ]; then
        log_info "802.11k (RRM) aktivieren"
        uci_batch_add "set wireless.wlan_ap5g.ieee80211k='1'"
        uci_batch_add "set wireless.wlan_ap5g.rrm_neighbor_report='1'"
        uci_batch_add "set wireless.wlan_ap5g.rrm_beacon_report='1'"
    fi

    # 802.11v
    if [ "${ENABLE_11V}" -eq 1 ]; then
        log_info "802.11v (BTM) aktivieren"
        uci_batch_add "set wireless.wlan_ap5g.ieee80211v='1'"
        uci_batch_add "set wireless.wlan_ap5g.bss_transition='1'"
        uci_batch_add "set wireless.wlan_ap5g.wnm_sleep_mode='0'"
    fi

    # 2G AP (optional, kein 11r auf 2.4G empfohlen)
    uci_batch_add "set wireless.wlan_ap2g=wifi-iface"
    uci_batch_add "set wireless.wlan_ap2g.device='radio1'"
    uci_batch_add "set wireless.wlan_ap2g.mode='ap'"
    uci_batch_add "set wireless.wlan_ap2g.ssid='${CFG_SSID_MAIN}'"
    uci_batch_add "set wireless.wlan_ap2g.encryption='${enc}'"
    uci_batch_add "set wireless.wlan_ap2g.key='${CFG_PASS_MAIN}'"
    uci_batch_add "set wireless.wlan_ap2g.network='lan'"
    uci_batch_add "set wireless.wlan_ap2g.ieee80211w='2'"
    uci_batch_add "set wireless.wlan_ap2g.sae_pwe='2'"
    uci_batch_add "set wireless.wlan_ap2g.${MANAGED_MARKER}='1'"
    [ "${ENABLE_11K}" -eq 1 ] && uci_batch_add "set wireless.wlan_ap2g.ieee80211k='1'"
    [ "${ENABLE_11V}" -eq 1 ] && uci_batch_add "set wireless.wlan_ap2g.bss_transition='1'"

    # r0kh/r1kh nur wenn 11r aktiv
    if [ "${ENABLE_11R}" -eq 1 ]; then
        render_r0kh_r1kh "wlan_ap5g"
    fi

    render_network_lan
    log_ok "Profil ap_roaming gerendert"
}

# =============================================================================
# RENDER: r0kh/r1kh UCI List (802.11r Multi-AP)
# Format hostapd: r0kh = "<nas_id> <ip> <key>", r1kh = "<r1kh_id> <addr> <key>"
# =============================================================================
render_r0kh_r1kh() {
    local iface="$1"
    local i=0 nas_id ip key r1kh_id addr

    # r0kh entries
    i=0
    while [ $i -le 20 ]; do
        nas_id="$(jf "${MASTER_JSON}" "$.roaming.r0kh[${i}].nas_id" 2>/dev/null)"
        [ -z "${nas_id}" ] && break
        ip="$(jf "${MASTER_JSON}" "$.roaming.r0kh[${i}].ip")"
        key="$(jf "${MASTER_JSON}" "$.roaming.r0kh[${i}].key")"
        uci_batch_add "list wireless.${iface}.r0kh='${nas_id} ${ip} ${key}'"
        log_info "r0kh[${i}]: ${nas_id} ${ip}"
        i=$((i + 1))
    done
    [ $i -eq 0 ] && log_warn "Keine r0kh-Einträge in master.json (roaming.r0kh)"

    # r1kh entries
    i=0
    while [ $i -le 20 ]; do
        r1kh_id="$(jf "${MASTER_JSON}" "$.roaming.r1kh[${i}].r1kh_id" 2>/dev/null)"
        [ -z "${r1kh_id}" ] && break
        addr="$(jf "${MASTER_JSON}" "$.roaming.r1kh[${i}].addr")"
        key="$(jf "${MASTER_JSON}" "$.roaming.r1kh[${i}].key")"
        uci_batch_add "list wireless.${iface}.r1kh='${r1kh_id} ${addr} ${key}'"
        log_info "r1kh[${i}]: ${r1kh_id} ${addr}"
        i=$((i + 1))
    done
    [ $i -eq 0 ] && log_warn "Keine r1kh-Einträge in master.json (roaming.r1kh)"
}

