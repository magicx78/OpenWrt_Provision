render_profile() {
    uci_batch_init
    render_system
    render_radios

    case "${PROFILE}" in
        ap_roaming)        render_ap_roaming       || return 1 ;;
        mesh_11s_backhaul) render_mesh_11s_backhaul || return 1 ;;
        client_backhaul)   render_client_backhaul   || return 1 ;;
        guest_isolated)    render_guest_isolated    || return 1 ;;
    esac

    # mgmt-Interface immer rendern (alle Profile)
    render_mgmt_interface

    uci_batch_add "commit wireless"
    uci_batch_add "commit network"
    [ "${CHANGES_FIREWALL}" -eq 1 ] && uci_batch_add "commit firewall"
    [ "${CHANGES_DHCP}" -eq 1 ]     && uci_batch_add "commit dhcp"
    return 0
}

apply_config() {
    log_step "Wende UCI-Konfiguration an"
    local cfg_list="system wireless network"
    [ "${CHANGES_FIREWALL}" -eq 1 ] && cfg_list="${cfg_list} firewall"
    [ "${CHANGES_DHCP}" -eq 1 ]     && cfg_list="${cfg_list} dhcp"

    # Checksums vor Apply (für Änderungs-Erkennung)
    local sum_before sum_after
    sum_before="$(sha256sum /etc/config/wireless /etc/config/network 2>/dev/null)"

    local uci_out uci_rc
    uci_out="$(uci batch < "${UCI_BATCH_FILE}" 2>&1)"
    uci_rc=$?
    echo "${uci_out}" >> "${MAIN_LOG}"
    [ -n "${uci_out}" ] && log_info "uci batch output: ${uci_out}"
    if [ "${uci_rc}" -ne 0 ]; then
        log_fail "uci batch fehlgeschlagen (rc=${uci_rc}): ${uci_out}"
        return 1
    fi

    for cfg in ${cfg_list}; do
        uci commit "${cfg}" 2>/dev/null && log_ok "commit ${cfg}" || log_warn "commit ${cfg} - keine Änderung"
    done

    sum_after="$(sha256sum /etc/config/wireless /etc/config/network 2>/dev/null)"

    APPLY_TIME="$(date +%s)"

    # Selective reload
    if [ "${sum_before}" != "${sum_after}" ] || [ "${CHANGES_NETWORK}" -eq 1 ]; then
        log_step "Reloading: network"
        /etc/init.d/network reload 2>&1 | tee -a "${MAIN_LOG}"
        sleep 3
    fi

    if [ "${CHANGES_WIRELESS}" -eq 1 ]; then
        log_step "Reloading: wireless"
        wifi reload 2>&1 | tee -a "${MAIN_LOG}"
        sleep "${HEALTHCHECK_SLEEP}"
    fi

    if [ "${CHANGES_FIREWALL}" -eq 1 ]; then
        log_step "Reloading: firewall"
        /etc/init.d/firewall reload 2>&1 | tee -a "${MAIN_LOG}"
    fi

    if [ "${CHANGES_DHCP}" -eq 1 ]; then
        log_step "Restarting: dnsmasq"
        /etc/init.d/dnsmasq restart 2>&1 | tee -a "${MAIN_LOG}"
    fi

    log_ok "Apply abgeschlossen"
    return 0
}

# =============================================================================
# HEALTHCHECK
# =============================================================================
check_wireless_up() {
    log_step "Healthcheck: WLAN-Interfaces via ubus"
    local retries=0
    local max_retries=6

    while [ "${retries}" -lt "${max_retries}" ]; do
        local status; status="$(ubus call network.wireless status 2>/dev/null)"
        if [ -n "${status}" ]; then
            # Prüfe erwartete Interfaces je Profil
            case "${PROFILE}" in
                ap_roaming)
                    echo "${status}" | grep -q '"mode":"ap"' && {
                        log_ok "Healthcheck: AP-Mode Interface erkannt"
                        return 0
                    }
                    ;;
                mesh_11s_backhaul)
                    echo "${status}" | grep -q '"mode":"mesh"' && {
                        log_ok "Healthcheck: Mesh-Interface erkannt"
                        return 0
                    }
                    ;;
                client_backhaul)
                    echo "${status}" | grep -q '"mode":"sta"' && {
                        log_ok "Healthcheck: STA-Interface erkannt"
                        return 0
                    }
                    ;;
                guest_isolated)
                    echo "${status}" | grep -q "${CFG_SSID_GUEST}" && {
                        log_ok "Healthcheck: Guest-SSID erkannt"
                        return 0
                    }
                    ;;
            esac
        fi
        retries=$((retries + 1))
        log_info "Healthcheck: Warte auf WLAN... Versuch ${retries}/${max_retries}"
        sleep 5
    done

    log_fail "Healthcheck: WLAN-Interface nach ${HEALTHCHECK_TIMEOUT}s nicht gefunden"
    return 1
}

check_bridges_up() {
    log_step "Healthcheck: Bridge/VLAN-Interfaces"
    if ip link show type bridge 2>/dev/null | grep -q 'br-lan'; then
        log_ok "Healthcheck: br-lan UP"
    else
        log_warn "Healthcheck: br-lan nicht gefunden"
    fi

    # Gast-Bridge (nur bei guest_isolated)
    if [ "${PROFILE}" = "guest_isolated" ]; then
        if ip link 2>/dev/null | grep -q 'br-guest\|guest'; then
            log_ok "Healthcheck: Guest-Bridge UP"
        else
            log_fail "Healthcheck: Guest-Bridge nicht gefunden"
            return 1
        fi
    fi
    return 0
}

check_logread_errors() {
    log_step "Healthcheck: logread auf Fatal-Errors (letzte ${LOGREAD_WINDOW}s)"
    local errors
    errors="$(logread 2>/dev/null | tail -200 | grep -iE '(hostapd|netifd|wpa_supplicant).*\b(fatal|error|failed|FAILED)\b' | tail -10)"

    if [ -n "${errors}" ]; then
        log_fail "Healthcheck: Fatal-Errors im Log:"
        echo "${errors}" | while read -r line; do
            log_fail "  ${line}"
        done
        return 1
    fi
    log_ok "Healthcheck: Keine Fatal-Errors in logread"
    return 0
}

check_firewall_zones() {
    [ "${PROFILE}" != "guest_isolated" ] && return 0
    log_step "Healthcheck: Firewall-Zonen"
    if uci show firewall 2>/dev/null | grep -q "zone_guest"; then
        log_ok "Healthcheck: Firewall-Zone 'guest' konfiguriert"
    else
        log_fail "Healthcheck: Firewall-Zone 'guest' fehlt"
        return 1
    fi
    return 0
}

run_healthcheck() {
    local fail=0
    check_wireless_up  || fail=1
    check_bridges_up   || fail=1
    check_logread_errors && true  # Warnung, kein hard fail
    check_firewall_zones || fail=1

    if [ "${fail}" -ne 0 ]; then
        log_fail "Healthcheck fehlgeschlagen - leite Rollback ein"
        return 1
    fi
    log_ok "Alle Healthchecks bestanden"
    return 0
}

# =============================================================================
# ROLLBACK
# =============================================================================
find_latest_backup() {
    # Neuestes Backup für diese Node
    local latest
    latest="$(ls -1d "${BACKUP_BASE}"/*_node${NODE_ID}_* 2>/dev/null | sort | tail -1)"
    echo "${latest}"
}

do_rollback() {
    local backup_dir="$1"

    if [ -z "${backup_dir}" ]; then
        backup_dir="$(find_latest_backup)"
    fi

    if [ -z "${backup_dir}" ] || [ ! -d "${backup_dir}" ]; then
        log_fail "Rollback: Kein Backup gefunden für Node ${NODE_ID}"
        log_fail "Gesuchter Pfad: ${BACKUP_BASE}/*_node${NODE_ID}_*"
        return 1
    fi

    log_step "Rollback: Wiederherstelle aus ${backup_dir}"

    for cfg in network wireless firewall dhcp; do
        if [ -f "${backup_dir}/${cfg}" ]; then
            cp "${backup_dir}/${cfg}" "/etc/config/${cfg}" && \
                log_ok "Rollback: /etc/config/${cfg} wiederhergestellt" || {
                log_fail "Rollback: Konnte /etc/config/${cfg} nicht wiederherstellen"
                return 1
            }
        fi
    done

    log_step "Rollback: Reload nach Wiederherstellung"
    /etc/init.d/network reload 2>&1 | tee -a "${MAIN_LOG}"
    sleep 3
    wifi reload 2>&1 | tee -a "${MAIN_LOG}"
    sleep "${HEALTHCHECK_SLEEP}"
    /etc/init.d/firewall reload 2>&1 | tee -a "${MAIN_LOG}"
    /etc/init.d/dnsmasq restart 2>&1 | tee -a "${MAIN_LOG}"

    # Minimaler Healthcheck nach Rollback
    local status; status="$(ubus call network.wireless status 2>/dev/null)"
    if [ -n "${status}" ]; then
        log_ok "Rollback: WLAN-Subsystem antwortet"
    else
        log_warn "Rollback: WLAN-Subsystem antwortet nicht (kann transient sein)"
    fi

    log_ok "Rollback abgeschlossen: ${backup_dir}"
    return 0
}

# =============================================================================
# UCI DIFF (für Logging bei Fehler)
# =============================================================================
log_uci_diff() {
    log_step "UCI-Diff nach Fehler:"
    for cfg in wireless network firewall dhcp; do
        echo "--- uci show ${cfg} ---" >> "${STEP_LOG}"
        uci show "${cfg}" >> "${STEP_LOG}" 2>&1
    done
    log_info "UCI-State in: ${STEP_LOG}"
}

# =============================================================================
# CLEANUP
# =============================================================================
cleanup() {
    rm -f "${UCI_BATCH_FILE}" 2>/dev/null
}
trap cleanup EXIT INT TERM

# =============================================================================
# MAIN
# =============================================================================
main() {
    log_init
    parse_args "$@"

    echo "========================================"
    echo " provision v${VERSION}"
    echo " Node: ${NODE_ID}  Profil: ${PROFILE:-rollback}"
    echo " $(date)"
    echo "========================================"

    log_info "START: node=${NODE_ID} profile=${PROFILE} apply=${DO_APPLY} dry_run=${DRY_RUN} 11r=${ENABLE_11R} 11k=${ENABLE_11K} 11v=${ENABLE_11V}"

    # --- ROLLBACK MODE ---
    if [ "${DO_ROLLBACK}" -eq 1 ]; then
        log_step "Modus: ROLLBACK"
        load_master_json
        do_rollback "" || exit ${EXIT_ROLLBACK}
        log_ok "Rollback erfolgreich"
        exit ${EXIT_OK}
    fi

    # --- LOAD CONFIG ---
    load_master_json

    # --- VALIDATE ONLY ---
    if [ "${VALIDATE_ONLY}" -eq 1 ]; then
        run_validations || exit ${EXIT_VALIDATION}
        echo "  Validierung OK (--validate-only)"
        exit ${EXIT_OK}
    fi

    # --- PRE-VALIDATE ---
    run_validations || exit ${EXIT_VALIDATION}

    # --- DRY RUN ---
    if [ "${DRY_RUN}" -eq 1 ]; then
        log_step "Modus: DRY-RUN"
        render_profile || exit ${EXIT_VALIDATION}
        echo "  Dry-Run abgeschlossen. Kein Commit."
        exit ${EXIT_OK}
    fi

    # --- APPLY ---
    if [ "${DO_APPLY}" -eq 1 ]; then
        # Backup erstellen
        create_backup || {
            log_fail "Backup fehlgeschlagen - Apply abgebrochen"
            exit ${EXIT_APPLY}
        }

        # Render + Apply
        render_profile || {
            log_fail "Render fehlgeschlagen"
            exit ${EXIT_APPLY}
        }

        apply_config || {
            log_fail "Apply fehlgeschlagen (rc=${EXIT_APPLY})"
            log_uci_diff
            log_step "Auto-Rollback..."
            do_rollback "${BACKUP_DIR}" || {
                log_fail "Auto-Rollback fehlgeschlagen!"
                exit ${EXIT_ROLLBACK}
            }
            exit ${EXIT_APPLY}
        }

        # Healthcheck
        run_healthcheck || {
            log_fail "Healthcheck fehlgeschlagen (rc=${EXIT_HEALTHCHECK})"
            log_uci_diff
            log_step "Auto-Rollback wegen Healthcheck-Fehler..."
            do_rollback "${BACKUP_DIR}" || {
                log_fail "Auto-Rollback fehlgeschlagen!"
                exit ${EXIT_ROLLBACK}
            }
            exit ${EXIT_HEALTHCHECK}
        }

        log_ok "DONE: node=${NODE_ID} profile=${PROFILE} - Provisioning erfolgreich"
        echo "========================================"
        echo " Provisioning ERFOLGREICH"
        echo " Log: ${STEP_LOG}"
        echo "========================================"
        exit ${EXIT_OK}
    fi
}

main "$@"
